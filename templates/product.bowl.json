    "custom_liquid_zxhVct": {
      "type": "custom-liquid",
      "name": "Why Pet doing",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<style>\n  .pet-problem-banner {\n    padding: 40px 14px;\n    background: #ffffff;\n    font-family: Arial, Helvetica, sans-serif;\n  }\n\n  .pet-problem-wrap {\n    max-width: 1120px;\n    margin: 0 auto;\n  }\n\n  .pet-problem-header {\n    max-width: 720px;\n    margin: 0 auto 26px;\n    text-align: center;\n  }\n\n  .pet-problem-eyebrow {\n    margin: 0 0 10px;\n    font-size: 13px;\n    line-height: 1.2;\n    font-weight: 800;\n    letter-spacing: 0.8px;\n    text-transform: uppercase;\n    color: #1684e8;\n  }\n\n  .pet-problem-title {\n    margin: 0 0 10px;\n    font-size: clamp(27px, 4vw, 42px);\n    line-height: 1.08;\n    font-weight: 900;\n    color: #111827;\n    letter-spacing: -0.6px;\n  }\n\n  .pet-problem-title span {\n    color: #1684e8;\n  }\n\n  .pet-problem-subtitle {\n    margin: 0;\n    font-size: clamp(14px, 2vw, 17px);\n    line-height: 1.55;\n    font-weight: 500;\n    color: #4b5563;\n  }\n\n  .pet-problem-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: clamp(10px, 2vw, 16px);\n  }\n\n  .pet-problem-card {\n    background: #ffffff;\n    border: 1px solid #e5e7eb;\n    border-radius: 16px;\n    overflow: hidden;\n  }\n\n  .pet-problem-img-wrap {\n    position: relative;\n    background: #f5f7fb;\n  }\n\n  .pet-problem-card img {\n    width: 100%;\n    aspect-ratio: 1 / 0.9;\n    object-fit: cover;\n    display: block;\n  }\n\n  .pet-problem-label {\n    position: absolute;\n    left: 10px;\n    bottom: 10px;\n    padding: 6px 9px;\n    border-radius: 999px;\n    background: rgba(255, 255, 255, 0.92);\n    color: #111827;\n    font-size: 11.5px;\n    line-height: 1;\n    font-weight: 800;\n  }\n\n  .pet-problem-content {\n    padding: 14px 13px 15px;\n    text-align: left;\n  }\n\n  .pet-problem-text {\n    margin: 0 0 6px;\n    font-size: clamp(14px, 2vw, 16px);\n    line-height: 1.25;\n    font-weight: 850;\n    color: #111827;\n  }\n\n  .pet-problem-note {\n    margin: 0;\n    font-size: 12.5px;\n    line-height: 1.45;\n    font-weight: 500;\n    color: #6b7280;\n  }\n\n  .pet-brand-solution {\n    margin-top: 22px;\n    display: grid;\n    grid-template-columns: 1.15fr 0.85fr;\n    gap: 18px;\n    align-items: stretch;\n  }\n\n  .pet-brand-story {\n    padding: 20px;\n    border-radius: 18px;\n    background: #f3f8ff;\n    border: 1px solid #dbeaff;\n  }\n\n  .pet-brand-story-title {\n    margin: 0 0 8px;\n    font-size: clamp(19px, 2.5vw, 26px);\n    line-height: 1.18;\n    font-weight: 900;\n    color: #0f3f89;\n    letter-spacing: -0.4px;\n  }\n\n  .pet-brand-story-title span {\n    color: #1684e8;\n  }\n\n  .pet-brand-story-copy {\n    margin: 0;\n    font-size: 14.5px;\n    line-height: 1.6;\n    font-weight: 500;\n    color: #315c9b;\n  }\n\n  .pet-brand-points {\n    padding: 20px;\n    border-radius: 18px;\n    background: #ffffff;\n    border: 1px solid #e5e7eb;\n    display: grid;\n    gap: 11px;\n  }\n\n  .pet-brand-point {\n    display: grid;\n    grid-template-columns: 22px 1fr;\n    gap: 9px;\n    align-items: start;\n  }\n\n  .pet-brand-check {\n    width: 20px;\n    height: 20px;\n    border-radius: 50%;\n    background: #1684e8;\n    color: #ffffff;\n    font-size: 12px;\n    font-weight: 900;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-top: 1px;\n  }\n\n  .pet-brand-point strong {\n    display: block;\n    margin-bottom: 2px;\n    font-size: 13.5px;\n    line-height: 1.3;\n    font-weight: 850;\n    color: #111827;\n  }\n\n  .pet-brand-point span {\n    display: block;\n    font-size: 12.5px;\n    line-height: 1.4;\n    font-weight: 500;\n    color: #6b7280;\n  }\n\n  .pet-brand-trust {\n    margin-top: 16px;\n    padding-top: 14px;\n    border-top: 1px solid #e5e7eb;\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 8px;\n  }\n\n  .pet-brand-trust span {\n    font-size: 12.5px;\n    line-height: 1;\n    font-weight: 700;\n    color: #0b3f91;\n    background: #f3f8ff;\n    border-radius: 999px;\n    padding: 7px 10px;\n  }\n\n  @media (max-width: 768px) {\n    .pet-problem-banner {\n      padding: 34px 12px;\n    }\n\n    .pet-problem-header {\n      margin-bottom: 22px;\n    }\n\n    .pet-problem-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n\n    .pet-problem-card {\n      border-radius: 14px;\n    }\n\n    .pet-problem-content {\n      padding: 12px 11px 13px;\n    }\n\n    .pet-brand-solution {\n      grid-template-columns: 1fr;\n      gap: 12px;\n    }\n\n    .pet-brand-story,\n    .pet-brand-points {\n      padding: 16px;\n      border-radius: 16px;\n    }\n\n    .pet-brand-story-copy {\n      font-size: 13.8px;\n    }\n  }\n\n  @media (max-width: 380px) {\n    .pet-problem-grid {\n      gap: 10px;\n    }\n\n    .pet-problem-text {\n      font-size: 13.5px;\n    }\n\n    .pet-problem-note {\n      font-size: 11.7px;\n    }\n\n    .pet-brand-trust span {\n      font-size: 12px;\n      padding: 6px 9px;\n    }\n  }\n</style>\n\n<section class=\"pet-problem-banner\">\n  <div class=\"pet-problem-wrap\">\n\n    <div class=\"pet-problem-header\">\n      <p class=\"pet-problem-eyebrow\">Mealtime Enrichment</p>\n\n      <h2 class=\"pet-problem-title\">\n        Built for Pets Who Need <span>More Than a Bowl</span>\n      </h2>\n\n      <p class=\"pet-problem-subtitle\">\n        A simple enrichment feeder designed to make treat time slower, cleaner, and more engaging for everyday use.\n      </p>\n    </div>\n\n    <div class=\"pet-problem-grid\">\n      <div class=\"pet-problem-card\">\n        <div class=\"pet-problem-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/1_b6a9f306-d11d-4bb7-805e-bd8d79bbb544.png?v=1778179984\" alt=\"Dog eating too fast\">\n          <span class=\"pet-problem-label\">Fast eating</span>\n        </div>\n        <div class=\"pet-problem-content\">\n          <p class=\"pet-problem-text\">Encourages slower feeding</p>\n          <p class=\"pet-problem-note\">Helps pets work for their reward instead of finishing treats too quickly.</p>\n        </div>\n      </div>\n\n      <div class=\"pet-problem-card\">\n        <div class=\"pet-problem-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/2.png?v=1778179983\" alt=\"Pet making a mess while eating\">\n          <span class=\"pet-problem-label\">Messy snacks</span>\n        </div>\n        <div class=\"pet-problem-content\">\n          <p class=\"pet-problem-text\">Designed for cleaner treat time</p>\n          <p class=\"pet-problem-note\">Helps keep spreads and wet food more contained during play.</p>\n        </div>\n      </div>\n\n      <div class=\"pet-problem-card\">\n        <div class=\"pet-problem-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/3.png?v=1778179983\" alt=\"Pet getting bored easily\">\n          <span class=\"pet-problem-label\">Boredom</span>\n        </div>\n        <div class=\"pet-problem-content\">\n          <p class=\"pet-problem-text\">Adds mental stimulation</p>\n          <p class=\"pet-problem-note\">Turns favorite foods into a more interactive, longer-lasting activity.</p>\n        </div>\n      </div>\n\n      <div class=\"pet-problem-card\">\n        <div class=\"pet-problem-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/4.png?v=1778179983\" alt=\"Dog showing anxiety\">\n          <span class=\"pet-problem-label\">Restless pets</span>\n        </div>\n        <div class=\"pet-problem-content\">\n          <p class=\"pet-problem-text\">Keeps pets calmly engaged</p>\n          <p class=\"pet-problem-note\">Provides a focused reward-based activity during quiet time at home.</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"pet-brand-solution\">\n      <div class=\"pet-brand-story\">\n        <h3 class=\"pet-brand-story-title\">\n          A better way to serve their <span>favorite treats.</span>\n        </h3>\n        <p class=\"pet-brand-story-copy\">\n          Fill it with yogurt, broth, peanut butter, or wet food. As your pet rolls and licks, snack time becomes a slower, more enriching routine that supports calmer behavior and cleaner feeding.\n        </p>\n\n        <div class=\"pet-brand-trust\">\n          <span>Food-grade material</span>\n          <span>Easy to clean</span>\n          <span>For dogs &amp; cats</span>\n        </div>\n      </div>\n\n      <div class=\"pet-brand-points\">\n        <div class=\"pet-brand-point\">\n          <span class=\"pet-brand-check\">✓</span>\n          <div>\n            <strong>Slow-feeding support</strong>\n            <span>Helps make treats last longer.</span>\n          </div>\n        </div>\n\n        <div class=\"pet-brand-point\">\n          <span class=\"pet-brand-check\">✓</span>\n          <div>\n            <strong>Daily enrichment</strong>\n            <span>Great for keeping pets occupied at home.</span>\n          </div>\n        </div>\n\n        <div class=\"pet-brand-point\">\n          <span class=\"pet-brand-check\">✓</span>\n          <div>\n            <strong>Rolling ball design</strong>\n            <span>Encourages natural curiosity and play.</span>\n          </div>\n        </div>\n\n        <div class=\"pet-brand-point\">\n          <span class=\"pet-brand-check\">✓</span>\n          <div>\n            <strong>Cleaner feeding</strong>\n            <span>Made to help reduce spills and mess.</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n</section>",
        "color_scheme": "background-1",
        "padding_top": 40,
        "padding_bottom": 0
      }
    },
    "custom_liquid_RWjJFz": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<div class=\"pawosa-results\">\n  <div class=\"pawosa-results__header\">\n    <p class=\"pawosa-results__eyebrow\">Pawosa Rolling Lick Bowl</p>\n\n    <h2>\n      A Calmer Way to Make Treat Time\n      <span>Slower, Cleaner & More Engaging</span>\n    </h2>\n\n    <p>\n      Designed for pets who eat too fast, get bored easily, or need a more enriching snack routine at home.\n    </p>\n  </div>\n\n  <div class=\"pawosa-results__top\">\n    <div class=\"pawosa-results__image\">\n      <img\n        src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/1_b6a9f306-d11d-4bb7-805e-bd8d79bbb544.png?v=1778179984\"\n        alt=\"Dog using Pawosa Rolling Lick Bowl\"\n      >\n    </div>\n\n    <div class=\"pawosa-results__benefits\">\n      <div class=\"result-card\">\n        <div class=\"result-icon\">⏱️</div>\n        <h3>Supports Slower Eating</h3>\n        <p>Encourages pets to lick and work for treats instead of finishing food too quickly.</p>\n      </div>\n\n      <div class=\"result-card\">\n        <div class=\"result-icon\">🧠</div>\n        <h3>Daily Mental Enrichment</h3>\n        <p>Turns yogurt, broth, wet food, or peanut butter into a longer-lasting activity.</p>\n      </div>\n\n      <div class=\"result-card\">\n        <div class=\"result-icon\">🧼</div>\n        <h3>Helps Reduce Mess</h3>\n        <p>The anti-spill design helps keep soft treats more contained during use.</p>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"pawosa-results__compare\">\n    <div class=\"compare-card before\">\n      <div class=\"compare-heading\">\n        <span>Before</span>\n        <h3>Traditional Treat Time</h3>\n      </div>\n\n      <div class=\"compare-content\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/2.png?v=1778179983\"\n          alt=\"Pet making a mess with traditional feeding\"\n        >\n\n        <ul>\n          <li>Eats treats too quickly</li>\n          <li>More spills and cleanup</li>\n          <li>Gets bored soon after</li>\n          <li>Less mental stimulation</li>\n        </ul>\n      </div>\n    </div>\n\n    <div class=\"compare-card after\">\n      <div class=\"compare-heading\">\n        <span>After</span>\n        <h3>Pawosa Rolling Lick Bowl</h3>\n      </div>\n\n      <div class=\"compare-content\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/h3.png?v=1778180857\"\n          alt=\"Dog using Pawosa Rolling Lick Bowl\"\n        >\n\n        <ul>\n          <li>Encourages slower licking</li>\n          <li>Keeps treats more contained</li>\n          <li>Helps pets stay engaged</li>\n          <li>Adds enrichment to daily routine</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"pawosa-results__trust\">\n    <div>\n      <strong>Food-Grade Material</strong>\n      <span>Made for everyday treat use</span>\n    </div>\n\n    <div>\n      <strong>Easy to Clean</strong>\n      <span>Simple design for daily routines</span>\n    </div>\n\n    <div>\n      <strong>Dogs &amp; Cats Friendly</strong>\n      <span>Works with soft treats and wet food</span>\n    </div>\n\n    <div>\n      <strong>Pet-Friendly Design</strong>\n      <span>Built for slower, calmer enrichment</span>\n    </div>\n  </div>\n</div>\n\n<style>\n  .pawosa-results {\n    max-width: 1280px;\n    margin: 0 auto;\n    padding: 48px 24px;\n    background: linear-gradient(180deg, #ffffff 0%, #f5f9ff 100%);\n    border-radius: 24px;\n    font-family: Arial, Helvetica, sans-serif;\n    color: #07172f;\n    overflow: hidden;\n  }\n\n  .pawosa-results * {\n    box-sizing: border-box;\n  }\n\n  .pawosa-results__header {\n    max-width: 820px;\n    margin: 0 auto 30px;\n    text-align: center;\n  }\n\n  .pawosa-results__eyebrow {\n    display: inline-flex;\n    margin: 0 0 12px;\n    padding: 7px 14px;\n    border-radius: 999px;\n    background: #eef6ff;\n    color: #1478ff;\n    font-size: 12px;\n    line-height: 1;\n    font-weight: 800;\n    letter-spacing: 0.05em;\n    text-transform: uppercase;\n  }\n\n  .pawosa-results__header h2 {\n    margin: 0;\n    font-size: clamp(32px, 5vw, 58px);\n    line-height: 1.08;\n    font-weight: 900;\n    letter-spacing: -0.04em;\n    color: #07172f;\n  }\n\n  .pawosa-results__header h2 span {\n    display: block;\n    color: #1478ff;\n  }\n\n  .pawosa-results__header p {\n    max-width: 700px;\n    margin: 14px auto 0;\n    font-size: clamp(15px, 2vw, 18px);\n    line-height: 1.55;\n    color: #536176;\n    font-weight: 500;\n  }\n\n  .pawosa-results__top {\n    display: grid;\n    grid-template-columns: 34% 1fr;\n    gap: 24px;\n    align-items: stretch;\n  }\n\n  .pawosa-results__image img {\n    width: 100%;\n    height: 100%;\n    min-height: 360px;\n    object-fit: cover;\n    border-radius: 20px;\n    display: block;\n  }\n\n  .pawosa-results__benefits {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px;\n    align-items: stretch;\n  }\n\n  .result-card {\n    background: #ffffff;\n    border-radius: 18px;\n    padding: 28px 20px;\n    text-align: center;\n    border: 1px solid #dbeaff;\n  }\n\n  .result-icon {\n    width: 74px;\n    height: 74px;\n    margin: 0 auto 16px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: #f1f7ff;\n    border-radius: 50%;\n    font-size: 34px;\n  }\n\n  .result-card h3 {\n    margin: 0 0 10px;\n    font-size: clamp(18px, 1.8vw, 22px);\n    line-height: 1.2;\n    font-weight: 900;\n    color: #101828;\n  }\n\n  .result-card p {\n    margin: 0;\n    font-size: 15px;\n    line-height: 1.5;\n    color: #536176;\n    font-weight: 500;\n  }\n\n  .pawosa-results__compare {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    margin-top: 24px;\n    align-items: stretch;\n  }\n\n  .compare-card {\n    background: #ffffff;\n    border-radius: 20px;\n    padding: 24px;\n    border: 1px solid #dbeaff;\n  }\n\n  .compare-heading {\n    margin-bottom: 18px;\n  }\n\n  .compare-heading span {\n    display: inline-flex;\n    margin-bottom: 8px;\n    padding: 6px 10px;\n    border-radius: 999px;\n    font-size: 12px;\n    line-height: 1;\n    font-weight: 800;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n  }\n\n  .compare-card.before .compare-heading span {\n    background: #fff1f1;\n    color: #d92d20;\n  }\n\n  .compare-card.after .compare-heading span {\n    background: #eef6ff;\n    color: #1478ff;\n  }\n\n  .compare-heading h3 {\n    margin: 0;\n    font-size: clamp(20px, 2vw, 26px);\n    line-height: 1.18;\n    color: #07172f;\n    font-weight: 900;\n    letter-spacing: -0.03em;\n  }\n\n  .compare-content {\n    display: grid;\n    grid-template-columns: 44% 1fr;\n    gap: 18px;\n    align-items: center;\n  }\n\n  .compare-content img {\n    width: 100%;\n    aspect-ratio: 1.25 / 1;\n    object-fit: cover;\n    border-radius: 14px;\n    display: block;\n  }\n\n  .compare-content ul {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n  }\n\n  .compare-content li {\n    position: relative;\n    margin-bottom: 11px;\n    padding-left: 28px;\n    font-size: 15px;\n    line-height: 1.35;\n    color: #344054;\n    font-weight: 600;\n  }\n\n  .compare-content li:last-child {\n    margin-bottom: 0;\n  }\n\n  .compare-card.before li::before {\n    content: \"×\";\n    position: absolute;\n    left: 0;\n    top: 0;\n    background: #ef3b3b;\n    color: #ffffff;\n    width: 19px;\n    height: 19px;\n    border-radius: 50%;\n    font-size: 14px;\n    line-height: 19px;\n    text-align: center;\n    font-weight: 900;\n  }\n\n  .compare-card.after li::before {\n    content: \"✓\";\n    position: absolute;\n    left: 0;\n    top: 0;\n    background: #1478ff;\n    color: #ffffff;\n    width: 19px;\n    height: 19px;\n    border-radius: 50%;\n    font-size: 12px;\n    line-height: 19px;\n    text-align: center;\n    font-weight: 900;\n  }\n\n  .pawosa-results__trust {\n    margin-top: 22px;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    background: #ffffff;\n    border: 1px solid #dbeaff;\n    border-radius: 18px;\n    overflow: hidden;\n  }\n\n  .pawosa-results__trust div {\n    padding: 17px 14px;\n    text-align: center;\n    border-right: 1px solid #dbeaff;\n  }\n\n  .pawosa-results__trust div:last-child {\n    border-right: none;\n  }\n\n  .pawosa-results__trust strong {\n    display: block;\n    margin-bottom: 5px;\n    font-size: 14.5px;\n    line-height: 1.25;\n    font-weight: 900;\n    color: #0f3f89;\n  }\n\n  .pawosa-results__trust span {\n    display: block;\n    font-size: 12.5px;\n    line-height: 1.35;\n    font-weight: 500;\n    color: #64748b;\n  }\n\n  @media (max-width: 1100px) {\n    .pawosa-results__top {\n      grid-template-columns: 1fr;\n    }\n\n    .pawosa-results__image img {\n      max-height: 420px;\n    }\n\n    .pawosa-results__benefits {\n      grid-template-columns: repeat(3, 1fr);\n    }\n\n    .pawosa-results__trust {\n      grid-template-columns: repeat(2, 1fr);\n    }\n\n    .pawosa-results__trust div:nth-child(2) {\n      border-right: none;\n    }\n\n    .pawosa-results__trust div:nth-child(1),\n    .pawosa-results__trust div:nth-child(2) {\n      border-bottom: 1px solid #dbeaff;\n    }\n  }\n\n  @media (max-width: 768px) {\n    .pawosa-results {\n      padding: 34px 14px;\n      border-radius: 18px;\n    }\n\n    .pawosa-results__header {\n      margin-bottom: 24px;\n    }\n\n    .pawosa-results__header h2 {\n      font-size: 34px;\n    }\n\n    .pawosa-results__benefits {\n      grid-template-columns: 1fr;\n      gap: 14px;\n    }\n\n    .result-card {\n      padding: 22px 18px;\n    }\n\n    .result-icon {\n      width: 64px;\n      height: 64px;\n      font-size: 30px;\n      margin-bottom: 14px;\n    }\n\n    .pawosa-results__compare {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n\n    .compare-card {\n      padding: 20px 16px;\n    }\n\n    .compare-heading {\n      text-align: center;\n    }\n\n    .compare-content {\n      grid-template-columns: 1fr;\n    }\n\n    .compare-content li {\n      font-size: 14.5px;\n    }\n\n    .pawosa-results__trust {\n      grid-template-columns: 1fr;\n    }\n\n    .pawosa-results__trust div {\n      border-right: none;\n      border-bottom: 1px solid #dbeaff;\n    }\n\n    .pawosa-results__trust div:last-child {\n      border-bottom: none;\n    }\n  }\n\n  @media (max-width: 420px) {\n    .pawosa-results {\n      padding-left: 12px;\n      padding-right: 12px;\n    }\n\n    .pawosa-results__header h2 {\n      font-size: 30px;\n    }\n\n    .pawosa-results__header p {\n      font-size: 14px;\n    }\n\n    .result-card p,\n    .compare-content li {\n      font-size: 13.5px;\n    }\n\n    .pawosa-results__trust strong {\n      font-size: 14px;\n    }\n\n    .pawosa-results__trust span {\n      font-size: 12px;\n    }\n  }\n</style>",
