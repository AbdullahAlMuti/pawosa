    "custom_liquid_QtxpEd": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<section class=\"pawosa-testimonials\">\n  <div class=\"pt-head\">\n    <span>Loved by Pet Parents 🐾</span>\n    <h2>Real Customers. Happy Pets.</h2>\n    <p>Trusted by pet owners for slower feeding, less mess, and daily enrichment.</p>\n  </div>\n\n  <div class=\"pt-wrap\">\n    <button class=\"pt-arrow pt-prev\" type=\"button\" aria-label=\"Previous testimonials\">‹</button>\n\n    <div class=\"pt-carousel\">\n      <div class=\"pt-track\">\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“My dog eats slower and stays busy much longer.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Jessica\" alt=\"Jessica M avatar\">\n            <div><strong>Jessica M.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“No more messy floors. Feeding time feels easier now.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=David\" alt=\"David R avatar\">\n            <div><strong>David R.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“Perfect for yogurt and broth. My dog loves it.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Sarah\" alt=\"Sarah K avatar\">\n            <div><strong>Sarah K.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“Turns snack time into a calm little activity.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Amanda\" alt=\"Amanda L avatar\">\n            <div><strong>Amanda L.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“Easy to clean and my dog eats much slower.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Michael\" alt=\"Michael T avatar\">\n            <div><strong>Michael T.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“Great for frozen treats while I work from home.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Emily\" alt=\"Emily P avatar\">\n            <div><strong>Emily P.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“My senior dog enjoys it and doesn’t rush anymore.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Robert\" alt=\"Robert J avatar\">\n            <div><strong>Robert J.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“Keeps my puppy focused instead of making a mess.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Olivia\" alt=\"Olivia B avatar\">\n            <div><strong>Olivia B.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“Simple product, but it really helps with boredom.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Daniel\" alt=\"Daniel C avatar\">\n            <div><strong>Daniel C.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“My cat actually uses it. Great for wet food.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Mia\" alt=\"Mia S avatar\">\n            <div><strong>Mia S.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“Less gulping, more licking. Exactly what I needed.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Chris\" alt=\"Chris A avatar\">\n            <div><strong>Chris A.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-stars\">★★★★★</div>\n          <p>“Looks nice, works well, and cleans quickly.”</p>\n          <div class=\"pt-user\">\n            <img src=\"https://api.dicebear.com/7.x/adventurer/svg?seed=Natalie\" alt=\"Natalie W avatar\">\n            <div><strong>Natalie W.</strong><span>Verified Buyer</span></div>\n          </div>\n        </article>\n\n      </div>\n    </div>\n\n    <button class=\"pt-arrow pt-next\" type=\"button\" aria-label=\"Next testimonials\">›</button>\n  </div>\n</section>\n\n<style>\n  .pawosa-testimonials {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 34px 14px;\n    background: #ffffff;\n    font-family: Arial, Helvetica, sans-serif;\n    color: #07172f;\n    overflow: hidden;\n  }\n\n  .pawosa-testimonials * {\n    box-sizing: border-box;\n  }\n\n  .pt-head {\n    text-align: center;\n    max-width: 680px;\n    margin: 0 auto 22px;\n  }\n\n  .pt-head span {\n    display: inline-block;\n    margin-bottom: 8px;\n    padding: 6px 12px;\n    border-radius: 999px;\n    background: #eef6ff;\n    color: #1478ff;\n    font-size: 12px;\n    font-weight: 800;\n  }\n\n  .pt-head h2 {\n    margin: 0;\n    font-size: clamp(26px, 4vw, 42px);\n    line-height: 1.08;\n    font-weight: 900;\n    letter-spacing: -0.04em;\n  }\n\n  .pt-head p {\n    margin: 10px auto 0;\n    font-size: 15px;\n    line-height: 1.45;\n    color: #536176;\n    font-weight: 500;\n  }\n\n  .pt-wrap {\n    position: relative;\n  }\n\n  .pt-carousel {\n    overflow: hidden;\n  }\n\n  .pt-track {\n    display: flex;\n    gap: 10px;\n    transition: transform 0.35s ease;\n  }\n\n  .pt-card {\n    flex: 0 0 calc((100% - 50px) / 6);\n    min-width: calc((100% - 50px) / 6);\n    background: #f7fbff;\n    border: 1px solid #dbeaff;\n    border-radius: 14px;\n    padding: 14px;\n  }\n\n  .pt-stars {\n    color: #ffb800;\n    font-size: 14px;\n    letter-spacing: 1px;\n    margin-bottom: 8px;\n    line-height: 1;\n  }\n\n  .pt-card p {\n    margin: 0 0 12px;\n    min-height: 54px;\n    font-size: 13px;\n    line-height: 1.35;\n    font-weight: 600;\n    color: #111827;\n  }\n\n  .pt-user {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .pt-user img {\n    width: 34px;\n    height: 34px;\n    border-radius: 50%;\n    background: #eaf4ff;\n    border: 1px solid #dcecff;\n    flex-shrink: 0;\n  }\n\n  .pt-user strong {\n    display: block;\n    font-size: 12.5px;\n    line-height: 1.1;\n    font-weight: 900;\n    color: #07172f;\n  }\n\n  .pt-user span {\n    display: block;\n    margin-top: 2px;\n    font-size: 11px;\n    line-height: 1.1;\n    font-weight: 700;\n    color: #1478ff;\n  }\n\n  .pt-arrow {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    z-index: 5;\n    width: 34px;\n    height: 34px;\n    border: 1px solid #dbeaff;\n    border-radius: 50%;\n    background: #ffffff;\n    color: #1478ff;\n    font-size: 26px;\n    line-height: 1;\n    font-weight: 700;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .pt-prev {\n    left: -6px;\n  }\n\n  .pt-next {\n    right: -6px;\n  }\n\n  .pt-arrow.is-disabled {\n    opacity: 0.35;\n    cursor: not-allowed;\n  }\n\n  @media (max-width: 990px) {\n    .pt-card {\n      flex-basis: calc((100% - 20px) / 3);\n      min-width: calc((100% - 20px) / 3);\n    }\n  }\n\n  @media (max-width: 640px) {\n    .pawosa-testimonials {\n      padding: 30px 10px;\n    }\n\n    .pt-head {\n      margin-bottom: 18px;\n    }\n\n    .pt-head h2 {\n      font-size: 28px;\n    }\n\n    .pt-head p {\n      font-size: 14px;\n    }\n\n    .pt-card {\n      flex-basis: calc((100% - 10px) / 2);\n      min-width: calc((100% - 10px) / 2);\n      padding: 12px;\n    }\n\n    .pt-card p {\n      font-size: 12.5px;\n      min-height: 50px;\n    }\n\n    .pt-arrow {\n      width: 30px;\n      height: 30px;\n      font-size: 22px;\n    }\n\n    .pt-prev {\n      left: 0;\n    }\n\n    .pt-next {\n      right: 0;\n    }\n  }\n\n  @media (max-width: 420px) {\n    .pt-card {\n      flex-basis: 100%;\n      min-width: 100%;\n    }\n  }\n</style>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    document.querySelectorAll(\".pawosa-testimonials\").forEach(function (section) {\n      const track = section.querySelector(\".pt-track\");\n      const cards = section.querySelectorAll(\".pt-card\");\n      const prev = section.querySelector(\".pt-prev\");\n      const next = section.querySelector(\".pt-next\");\n      let index = 0;\n\n      function visibleCards() {\n        if (window.innerWidth <= 420) return 1;\n        if (window.innerWidth <= 640) return 2;\n        if (window.innerWidth <= 990) return 3;\n        return 6;\n      }\n\n      function update() {\n        const gap = 10;\n        const visible = visibleCards();\n        const max = Math.max(cards.length - visible, 0);\n        const step = cards[0].offsetWidth + gap;\n\n        if (index > max) index = max;\n\n        track.style.transform = \"translateX(-\" + index * step + \"px)\";\n        prev.classList.toggle(\"is-disabled\", index === 0);\n        next.classList.toggle(\"is-disabled\", index === max);\n      }\n\n      next.addEventListener(\"click\", function () {\n        const max = Math.max(cards.length - visibleCards(), 0);\n        if (index < max) {\n          index++;\n          update();\n        }\n      });\n\n      prev.addEventListener(\"click\", function () {\n        if (index > 0) {\n          index--;\n          update();\n        }\n      });\n\n      window.addEventListener(\"resize\", update);\n      update();\n    });\n  });\n</script>",
