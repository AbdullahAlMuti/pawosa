in-height: 48px;\n        padding: 9px 6px;\n        font-size: 11.5px;\n      }\n\n      .pawosa-bowl-compare .pbc-top {\n        min-height: 44px;\n        font-size: 9.5px;\n      }\n\n      .pawosa-bowl-compare .pbc-choice {\n        width: 64px;\n        grid-template-columns: 19px 1fr;\n        column-gap: 5px;\n      }\n\n      .pawosa-bowl-compare .pbc-mark {\n        width: 19px;\n        height: 19px;\n        font-size: 10px;\n      }\n\n      .pawosa-bowl-compare .pbc-choice span:last-child {\n        font-size: 11px;\n      }\n    }\n  </style>\n\n  <div class=\"pbc-shell\">\n    <h2 class=\"pbc-heading\">\n      Why Choose <span>Pawosa?</span>\n    </h2>\n\n    <p class=\"pbc-subheading\">\n      A smarter play bowl designed for hydration, stability, easy cleaning, and safer everyday fun.\n    </p>\n\n    <div class=\"pbc-table-wrap\" aria-label=\"Pawosa bowl comparison\">\n      <div class=\"pbc-table\">\n        <div class=\"pbc-cell pbc-feature pbc-top pbc-top-feature\">Feature</div>\n        <div class=\"pbc-cell pbc-brand pbc-top pbc-top-brand\">Pawosa</div>\n        <div class=\"pbc-cell pbc-basic pbc-top pbc-top-basic\">Basic Bowl</div>\n\n        <div class=\"pbc-cell pbc-feature\">Encourages hydration</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Yes</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>No</span>\n          </div>\n        </div>\n\n        <div class=\"pbc-cell pbc-feature\">Anti-slip design</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Stable</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>Slides</span>\n          </div>\n        </div>\n\n        <div class=\"pbc-cell pbc-feature\">Food-grade material</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Safe</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>Varies</span>\n          </div>\n        </div>\n\n        <div class=\"pbc-cell pbc-feature\">Easy to clean</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Easy</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>Basic</span>\n          </div>\n        </div>\n\n        <div class=\"pbc-cell pbc-feature\">Built for play</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Fun</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>Limited</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>",
