      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<div class=\"rongora-results\">\n  <div class=\"rongora-results__header\">\n    <h2>\n      Real Results After Using\n      <span>Rongora Rolling Lick Bowl 🐾</span>\n    </h2>\n    <p>Happy Pets, Happier Lives</p>\n  </div>\n\n  <div class=\"rongora-results__top\">\n    <div class=\"rongora-results__image\">\n      <img\n        src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/1_b6a9f306-d11d-4bb7-805e-bd8d79bbb544.png?v=1778179984\"\n        alt=\"Dog using Rongora Rolling Lick Bowl\"\n      >\n    </div>\n\n    <div class=\"rongora-results__benefits\">\n      <div class=\"result-card\">\n        <div class=\"result-icon\">⏱️</div>\n        <span class=\"check\">✓</span>\n        <h3>Slower, Healthier<br>Eating Habits</h3>\n        <p>Helps reduce choking, bloating and overeating by encouraging slow feeding.</p>\n      </div>\n\n      <div class=\"result-card\">\n        <div class=\"result-icon\">🧠</div>\n        <span class=\"check\">✓</span>\n        <h3>Mental Stimulation<br>& Less Anxiety</h3>\n        <p>Keeps your pet mentally engaged, calm and entertained during feeding time.</p>\n      </div>\n\n      <div class=\"result-card\">\n        <div class=\"result-icon\">🛡️</div>\n        <span class=\"check\">✓</span>\n        <h3>No More<br>Messy Floors</h3>\n        <p>Anti-spill design helps keep food and liquid inside the bowl, not on your floor.</p>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"rongora-results__bottom\">\n    <div class=\"compare-card before\">\n      <h3>Before Using<br><span>Traditional Bowl</span></h3>\n\n      <div class=\"compare-content\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/2.png?v=1778179983\"\n          alt=\"Before using traditional pet bowl\"\n        >\n\n        <ul>\n          <li>Eats too fast</li>\n          <li>Food everywhere</li>\n          <li>Bored & anxious</li>\n          <li>More likely to choke</li>\n          <li>Poor digestion</li>\n        </ul>\n      </div>\n    </div>\n\n    <div class=\"compare-card after\">\n      <h3>After Using<br><span>Rongora Rolling Lick Bowl</span></h3>\n\n      <div class=\"compare-content\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/h3.png?v=1778180857\"\n          alt=\"After using Rongora Rolling Lick Bowl\"\n        >\n\n        <ul>\n          <li>Eats slow & steadily</li>\n          <li>No mess, no spills</li>\n          <li>Mentally engaged</li>\n          <li>Less anxiety</li>\n          <li>Better digestion</li>\n        </ul>\n      </div>\n    </div>\n\n    <div class=\"rating-card\">\n      <strong>98%</strong>\n      <div class=\"stars\">★★★★★</div>\n      <p>of pet parents noticed positive changes after using the Rongora Rolling Lick Bowl!</p>\n    </div>\n\n    <div class=\"vs-badge\">VS</div>\n  </div>\n\n  <div class=\"rongora-results__trust\">\n    <div>🛡️ Vet Approved</div>\n    <div>🌿 Food Grade Silicone</div>\n    <div>🧼 Dishwasher Safe</div>\n    <div>🐾 Loved by Pets Worldwide</div>\n  </div>\n</div>\n\n<style>\n  .rongora-results {\n    max-width: 1280px;\n    margin: 0 auto;\n    padding: 48px 24px;\n    background: linear-gradient(180deg, #ffffff 0%, #f4f9ff 100%);\n    border-radius: 24px;\n    font-family: inherit;\n    overflow: hidden;\n  }\n\n  .rongora-results__header {\n    text-align: center;\n    margin-bottom: 28px;\n  }\n\n  .rongora-results__header h2 {\n    margin: 0;\n    font-size: clamp(34px, 5vw, 64px);\n    line-height: 1.08;\n    font-weight: 900;\n    color: #07172f;\n  }\n\n  .rongora-results__header h2 span {\n    display: block;\n    color: #1478ff;\n  }\n\n  .rongora-results__header p {\n    margin: 12px 0 0;\n    font-size: clamp(18px, 2.2vw, 28px);\n    color: #24415f;\n    font-weight: 600;\n  }\n\n  .rongora-results__top {\n    display: grid;\n    grid-template-columns: 34% 1fr;\n    gap: 28px;\n    align-items: stretch;\n  }\n\n  .rongora-results__image img {\n    width: 100%;\n    height: 100%;\n    min-height: 360px;\n    object-fit: cover;\n    border-radius: 20px;\n    display: block;\n  }\n\n  .rongora-results__benefits {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 18px;\n    align-items: stretch;\n  }\n\n  .result-card {\n    position: relative;\n    background: #ffffff;\n    border-radius: 18px;\n    padding: 32px 22px;\n    text-align: center;\n    box-shadow: 0 8px 24px rgba(17, 104, 204, 0.08);\n    border: 1px solid #e6f0ff;\n  }\n\n  .result-icon {\n    width: 82px;\n    height: 82px;\n    margin: 0 auto 18px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: #f1f7ff;\n    border-radius: 50%;\n    font-size: 40px;\n  }\n\n  .check {\n    position: absolute;\n    top: 86px;\n    right: 28px;\n    width: 30px;\n    height: 30px;\n    background: #1976ff;\n    color: #fff;\n    border-radius: 50%;\n    font-size: 18px;\n    font-weight: 800;\n    line-height: 30px;\n  }\n\n  .result-card h3 {\n    margin: 0 0 12px;\n    font-size: 22px;\n    line-height: 1.2;\n    font-weight: 900;\n    color: #101828;\n  }\n\n  .result-card p {\n    margin: 0;\n    font-size: 16px;\n    line-height: 1.55;\n    color: #222;\n  }\n\n  .rongora-results__bottom {\n    position: relative;\n    display: grid;\n    grid-template-columns: 1.1fr 1.1fr 0.85fr;\n    gap: 24px;\n    margin-top: 30px;\n    align-items: stretch;\n  }\n\n  .compare-card,\n  .rating-card {\n    background: #ffffff;\n    border-radius: 20px;\n    padding: 26px;\n    box-shadow: 0 8px 24px rgba(17, 104, 204, 0.08);\n    border: 1px solid #e6f0ff;\n  }\n\n  .compare-card h3 {\n    margin: 0 0 18px;\n    font-size: 24px;\n    line-height: 1.2;\n    color: #07172f;\n    font-weight: 900;\n  }\n\n  .compare-card.before h3 span {\n    color: #e92828;\n  }\n\n  .compare-card.after h3 span {\n    color: #1478ff;\n  }\n\n  .compare-content {\n    display: grid;\n    grid-template-columns: 46% 1fr;\n    gap: 18px;\n    align-items: center;\n  }\n\n  .compare-content img {\n    width: 100%;\n    aspect-ratio: 1.35 / 1;\n    object-fit: cover;\n    border-radius: 14px;\n    display: block;\n  }\n\n  .compare-content ul {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n  }\n\n  .compare-content li {\n    position: relative;\n    margin-bottom: 12px;\n    padding-left: 30px;\n    font-size: 16px;\n    color: #111;\n  }\n\n  .compare-card.before li::before {\n    content: \"✕\";\n    position: absolute;\n    left: 0;\n    top: 0;\n    background: #ef3b3b;\n    color: #fff;\n    width: 20px;\n    height: 20px;\n    border-radius: 50%;\n    font-size: 13px;\n    line-height: 20px;\n    text-align: center;\n    font-weight: 800;\n  }\n\n  .compare-card.after li::before {\n    content: \"✓\";\n    position: absolute;\n    left: 0;\n    top: 0;\n    background: #8cc63f;\n    color: #fff;\n    width: 20px;\n    height: 20px;\n    border-radius: 50%;\n    font-size: 13px;\n    line-height: 20px;\n    text-align: center;\n    font-weight: 800;\n  }\n\n  .vs-badge {\n    position: absolute;\n    left: calc((100% - 48px) * 0.365);\n    top: 50%;\n    transform: translate(-50%, -50%);\n    z-index: 5;\n    width: 70px;\n    height: 70px;\n    border-radius: 50%;\n    background: #1478ff;\n    color: #fff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 26px;\n    font-weight: 900;\n    border: 6px solid #f4f9ff;\n    box-shadow: 0 10px 28px rgba(20, 120, 255, 0.28);\n  }\n\n  .rating-card {\n    text-align: center;\n    background: linear-gradient(180deg, #eef6ff 0%, #ffffff 100%);\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n\n  .rating-card strong {\n    display: block;\n    font-size: clamp(58px, 7vw, 88px);\n    line-height: 1;\n    font-weight: 900;\n    color: #1478ff;\n  }\n\n  .stars {\n    margin: 16px 0;\n    color: #ffb800;\n    font-size: 34px;\n    letter-spacing: 3px;\n  }\n\n  .rating-card p {\n    margin: 0;\n    font-size: 20px;\n    line-height: 1.35;\n    font-weight: 700;\n    color: #111;\n  }\n\n  .rongora-results__trust {\n    margin-top: 24px;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    background: #ffffff;\n    border: 1px solid #d9e9ff;\n    border-radius: 18px;\n    overflow: hidden;\n  }\n\n  .rongora-results__trust div {\n    padding: 18px 14px;\n    text-align: center;\n    font-size: 16px;\n    font-weight: 800;\n    color: #101828;\n    border-right: 1px solid #d9e9ff;\n  }\n\n  .rongora-results__trust div:last-child {\n    border-right: none;\n  }\n\n  @media (max-width: 1100px) {\n    .rongora-results__top {\n      grid-template-columns: 1fr;\n    }\n\n    .rongora-results__image img {\n      max-height: 420px;\n    }\n\n    .rongora-results__benefits {\n      grid-template-columns: repeat(3, 1fr);\n    }\n\n    .rongora-results__bottom {\n      grid-template-columns: 1fr;\n    }\n\n    .vs-badge {\n      position: relative;\n      left: auto;\n      top: auto;\n      transform: none;\n      margin: -12px auto;\n      grid-row: 2;\n    }\n\n    .rating-card {\n      grid-row: 4;\n    }\n\n    .rongora-results__trust {\n      grid-template-columns: repeat(2, 1fr);\n    }\n\n    .rongora-results__trust div:nth-child(2) {\n      border-right: none;\n    }\n\n    .rongora-results__trust div:nth-child(1),\n    .rongora-results__trust div:nth-child(2) {\n      border-bottom: 1px solid #d9e9ff;\n    }\n  }\n\n  @media (max-width: 768px) {\n    .rongora-results {\n      padding: 34px 14px;\n      border-radius: 18px;\n    }\n\n    .rongora-results__header h2 {\n      font-size: 34px;\n    }\n\n    .rongora-results__benefits {\n      grid-template-columns: 1fr;\n      gap: 16px;\n    }\n\n    .result-card {\n      padding: 24px 18px;\n    }\n\n    .result-card h3 {\n      font-size: 21px;\n    }\n\n    .compare-content {\n      grid-template-columns: 1fr;\n    }\n\n    .compare-card,\n    .rating-card {\n      padding: 22px 16px;\n    }\n\n    .compare-card h3 {\n      font-size: 22px;\n      text-align: center;\n    }\n\n    .compare-content li {\n      font-size: 15px;\n    }\n\n    .rating-card p {\n      font-size: 18px;\n    }\n\n    .stars {\n      font-size: 28px;\n    }\n\n    .rongora-results__trust {\n      grid-template-columns: 1fr;\n    }\n\n    .rongora-results__trust div {\n      border-right: none;\n      border-bottom: 1px solid #d9e9ff;\n    }\n\n    .rongora-results__trust div:last-child {\n      border-bottom: none;\n    }\n  }\n</style>",
