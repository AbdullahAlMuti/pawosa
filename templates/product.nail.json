    "custom_liquid_xERhcH": {
      "type": "custom-liquid",
      "name": "Why Need",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<div class=\"custom-liquid-reference-block\">\n  <style>\n    .custom-liquid-reference-block,\n    .custom-liquid-reference-block * {\n      box-sizing: border-box;\n    }\n\n    .custom-liquid-reference-block {\n      width: 100%;\n      padding: clamp(28px, 4vw, 56px) 16px clamp(22px, 3vw, 36px);\n      background: #fff8ed;\n      color: #102844;\n      overflow: hidden;\n      font-family: Arial, Helvetica, sans-serif;\n    }\n\n    .custom-liquid-reference-block .clrb-shell {\n      width: min(100%, 1480px);\n      margin: 0 auto;\n    }\n\n    .custom-liquid-reference-block .clrb-heading {\n      max-width: 980px;\n      margin: 0 auto clamp(18px, 2.4vw, 30px);\n      text-align: center;\n      font-family: Georgia, \"Times New Roman\", serif;\n      font-size: clamp(34px, 4.4vw, 68px);\n      line-height: 0.94;\n      font-weight: 900;\n      letter-spacing: -0.06em;\n      color: #102844;\n    }\n\n    .custom-liquid-reference-block .clrb-heading span {\n      color: #0b7f88;\n      font-style: italic;\n    }\n\n    .custom-liquid-reference-block .clrb-grid {\n      display: grid;\n      grid-template-columns: repeat(4, minmax(0, 1fr));\n      gap: clamp(16px, 1.8vw, 28px);\n      align-items: stretch;\n    }\n\n    .custom-liquid-reference-block .clrb-card {\n      min-width: 0;\n      padding: clamp(12px, 1.15vw, 17px);\n      background: #fffdf8;\n      border: 1px solid #ead9c3;\n      border-radius: clamp(18px, 1.5vw, 24px);\n    }\n\n    .custom-liquid-reference-block .clrb-card-head {\n      display: grid;\n      grid-template-columns: clamp(54px, 5vw, 78px) minmax(0, 1fr);\n      gap: clamp(9px, 0.9vw, 14px);\n      align-items: center;\n      min-height: clamp(82px, 6.2vw, 104px);\n      margin-bottom: clamp(10px, 1vw, 14px);\n    }\n\n    .custom-liquid-reference-block .clrb-icon {\n      width: clamp(54px, 5vw, 78px);\n      height: clamp(54px, 5vw, 78px);\n      border: 3px solid #0b7f88;\n      border-radius: 999px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      color: #0b7f88;\n      background: #e9f8f8;\n      flex: 0 0 auto;\n    }\n\n    .custom-liquid-reference-block .clrb-icon svg {\n      width: 70%;\n      height: 70%;\n      display: block;\n      stroke: currentColor;\n      fill: none;\n      stroke-width: 4.5;\n      stroke-linecap: round;\n      stroke-linejoin: round;\n    }\n\n    .custom-liquid-reference-block .clrb-title {\n      margin: 0 0 4px;\n      font-family: Georgia, \"Times New Roman\", serif;\n      font-size: clamp(17px, 1.35vw, 24px);\n      line-height: 0.98;\n      font-weight: 900;\n      letter-spacing: -0.045em;\n      color: #102844;\n    }\n\n    .custom-liquid-reference-block .clrb-copy {\n      margin: 0;\n      max-width: 250px;\n      font-size: clamp(12.5px, 0.96vw, 16px);\n      line-height: 1.26;\n      font-weight: 800;\n      color: #5a4d42;\n      letter-spacing: -0.018em;\n    }\n\n    .custom-liquid-reference-block .clrb-image-wrap {\n      width: 100%;\n      aspect-ratio: 2.45 / 1;\n      overflow: hidden;\n      border-radius: clamp(12px, 1vw, 16px);\n      background: #eadfce;\n      border: 1px solid #ead9c3;\n    }\n\n    .custom-liquid-reference-block .clrb-image {\n      width: 100%;\n      height: 100%;\n      display: block;\n      object-fit: cover;\n    }\n\n    .custom-liquid-reference-block .clrb-footer {\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      gap: clamp(10px, 1vw, 15px);\n      margin-top: clamp(18px, 2vw, 28px);\n      text-align: center;\n      color: #102844;\n    }\n\n    .custom-liquid-reference-block .clrb-paw {\n      width: clamp(34px, 3vw, 50px);\n      height: clamp(34px, 3vw, 50px);\n      color: #0b7f88;\n      flex: 0 0 auto;\n    }\n\n    .custom-liquid-reference-block .clrb-paw svg {\n      width: 100%;\n      height: 100%;\n      display: block;\n      fill: currentColor;\n    }\n\n    .custom-liquid-reference-block .clrb-footer-text {\n      margin: 0;\n      font-family: Georgia, \"Times New Roman\", serif;\n      font-size: clamp(22px, 2vw, 34px);\n      line-height: 1.02;\n      font-weight: 900;\n      letter-spacing: -0.05em;\n      color: #102844;\n    }\n\n    .custom-liquid-reference-block .clrb-footer-text span {\n      color: #0b7f88;\n      font-style: italic;\n    }\n\n    @media (max-width: 1180px) {\n      .custom-liquid-reference-block .clrb-grid {\n        gap: 16px;\n      }\n\n      .custom-liquid-reference-block .clrb-card {\n        padding: 12px;\n      }\n\n      .custom-liquid-reference-block .clrb-card-head {\n        grid-template-columns: 56px 1fr;\n        gap: 10px;\n      }\n\n      .custom-liquid-reference-block .clrb-icon {\n        width: 56px;\n        height: 56px;\n        border-width: 2.5px;\n      }\n    }\n\n    @media (max-width: 989px) {\n      .custom-liquid-reference-block {\n        padding: 34px 16px 28px;\n      }\n\n      .custom-liquid-reference-block .clrb-grid {\n        grid-template-columns: repeat(2, minmax(0, 1fr));\n        gap: 18px;\n      }\n\n      .custom-liquid-reference-block .clrb-card-head {\n        min-height: 82px;\n      }\n\n      .custom-liquid-reference-block .clrb-copy {\n        max-width: none;\n      }\n\n      .custom-liquid-reference-block .clrb-image-wrap {\n        aspect-ratio: 2.45 / 1;\n      }\n    }\n\n    @media (max-width: 640px) {\n      .custom-liquid-reference-block {\n        padding: 30px 10px 24px;\n      }\n\n      .custom-liquid-reference-block .clrb-heading {\n        max-width: 365px;\n        margin-bottom: 16px;\n        font-size: clamp(35px, 9.8vw, 46px);\n        line-height: 0.96;\n      }\n\n      .custom-liquid-reference-block .clrb-grid {\n        grid-template-columns: repeat(2, minmax(0, 1fr));\n        gap: 10px;\n      }\n\n      .custom-liquid-reference-block .clrb-card {\n        border-radius: 16px;\n        padding: 9px;\n      }\n\n      .custom-liquid-reference