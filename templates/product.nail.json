elvetica Neue\", Helvetica, Arial, sans-serif;\n    font-size: 15px;\n    line-height: 1.45;\n    font-weight: 500;\n    color: #174f58;\n  }\n\n  .pawosa-feature-grid {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 6px;\n  }\n\n  .pawosa-feature {\n    display: flex;\n    align-items: center;\n    gap: 9px;\n    min-height: 38px;\n    padding: 8px 11px;\n    border: 1px solid #bfe3e7;\n    border-radius: 6px;\n    background: #f1fafb;\n    color: #073f49;\n    font-family: \"Avenir Next\", Avenir, \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n    font-size: 13px;\n    line-height: 1.2;\n    font-weight: 650;\n    letter-spacing: -0.1px;\n  }\n\n  .pawosa-check {\n    flex: 0 0 auto;\n    width: 17px;\n    height: 17px;\n    border-radius: 50%;\n    background: #0f6f78;\n    color: #ffffff;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    font-family: \"Avenir Next\", Avenir, \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n    font-size: 11px;\n    line-height: 1;\n    font-weight: 800;\n  }\n\n  @media (max-width: 520px) {\n    .pawosa-section {\n      padding: 8px 0;\n    }\n\n    .pawosa-title {\n      font-size: 27px;\n      line-height: 1.08;\n      letter-spacing: -0.9px;\n    }\n\n    .pawosa-subtitle {\n      font-size: 14px;\n      line-height: 1.4;\n      margin-bottom: 10px;\n    }\n\n    .pawosa-feature-grid {\n      gap: 6px;\n    }\n\n    .pawosa-feature {\n      min-height: 36px;\n      padding: 7px 9px;\n      gap: 7px;\n      font-size: 12px;\n      border-radius: 6px;\n      font-weight: 650;\n    }\n\n    .pawosa-check {\n      width: 16px;\n      height: 16px;\n      font-size: 10px;\n    }\n  }\n</style>"
