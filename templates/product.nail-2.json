    "custom_liquid_tbXhC7": {
      "type": "custom-liquid",
      "name": "Shoes That",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<div class=\"dog-shoe-super\">\n  <div class=\"dog-shoe-super__inner\">\n\n    <div class=\"dog-shoe-super__copy\">\n      <div class=\"dog-shoe-super__proof-line\">\n        <span class=\"dog-shoe-super__stars\">★★★★★</span>\n        <span>Trusted by dog parents</span>\n      </div>\n\n      <h2 class=\"dog-shoe-super__title\">\n        <span>Shoes That</span>\n        <strong>Stay On</strong>\n      </h2>\n\n      <p class=\"dog-shoe-super__subtitle\">\n        Secure twist-lock dog shoes that protect paws, grip the ground, and stay put on real walks.\n      </p>\n\n      <div class=\"dog-shoe-super__pain-box\">\n        <strong>No more shoes flying off mid-walk.</strong>\n        <span>Twist to tighten. Pull slightly to loosen. Done in seconds.</span>\n      </div>\n\n      <div class=\"dog-shoe-super__benefits\">\n        <div>\n          <span>✓</span>\n          Won’t slip off\n        </div>\n        <div>\n          <span>✓</span>\n          Anti-slip grip\n        </div>\n        <div>\n          <span>✓</span>\n          Paw protection\n        </div>\n      </div>\n\n      <div class=\"dog-shoe-super__cta-wrap\">\n        <a href=\"/products/YOUR-PRODUCT-HANDLE\" class=\"dog-shoe-super__cta\">\n          Shop Now\n          <span>→</span>\n        </a>\n\n        <div class=\"dog-shoe-super__under-cta\">\n          Secure checkout • Fast shipping • Easy returns\n        </div>\n      </div>\n    </div>\n\n    <div class=\"dog-shoe-super__visual\">\n      <div class=\"dog-shoe-super__floating-badge dog-shoe-super__floating-badge--top\">\n        <strong>Twist-Lock</strong>\n        <span>secure fit</span>\n      </div>\n\n      <div class=\"dog-shoe-super__media\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0813/4626/5347/files/gif19.webp?v=1779106312\"\n          alt=\"Dog wearing secure twist-lock walking shoes\"\n          width=\"620\"\n          height=\"560\"\n          loading=\"eager\"\n          fetchpriority=\"high\"\n          decoding=\"async\"\n        >\n      </div>\n\n      <div class=\"dog-shoe-super__floating-badge dog-shoe-super__floating-badge--bottom\">\n        <strong>Easy Fit</strong>\n        <span>no straps</span>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<style>\n  .dog-shoe-super {\n    --orange: #ff5a00;\n    --orange-dark: #d94600;\n    --black: #080808;\n    --text: #333333;\n    --muted: #6a6a6a;\n    --border: #ededed;\n    --soft: #f7f7f7;\n    --orange-soft: #fff1e8;\n\n    width: 100%;\n    background: #ffffff;\n    padding: 58px 18px;\n    overflow: hidden;\n    font-family: Arial, Helvetica, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    text-rendering: geometricPrecision;\n  }\n\n  .dog-shoe-super * {\n    box-sizing: border-box;\n  }\n\n  .dog-shoe-super__inner {\n    max-width: 1240px;\n    min-height: 540px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 0.98fr 1.02fr;\n    align-items: center;\n    gap: 48px;\n  }\n\n  .dog-shoe-super__copy {\n    max-width: 590px;\n  }\n\n  .dog-shoe-super__proof-line {\n    display: inline-flex;\n    align-items: center;\n    gap: 9px;\n    margin-bottom: 16px;\n    padding: 9px 14px;\n    border-radius: 999px;\n    background: var(--orange-soft);\n    color: var(--black);\n    font-size: 14px;\n    line-height: 1;\n    font-weight: 850;\n    white-space: nowrap;\n  }\n\n  .dog-shoe-super__stars {\n    color: var(--orange);\n    font-weight: 950;\n    letter-spacing: 0.04em;\n  }\n\n  .dog-shoe-super__title {\n    margin: 0;\n    text-transform: uppercase;\n    line-height: 0.89;\n    letter-spacing: -0.066em;\n  }\n\n  .dog-shoe-super__title span,\n  .dog-shoe-super__title strong {\n    display: block;\n    white-space: nowrap;\n    font-size: clamp(58px, 6.6vw, 106px);\n    font-weight: 950;\n  }\n\n  .dog-shoe-super__title span {\n    color: var(--black);\n  }\n\n  .dog-shoe-super__title strong {\n    color: var(--orange);\n  }\n\n  .dog-shoe-super__subtitle {\n    max-width: 535px;\n    margin: 20px 0 0;\n    color: var(--text);\n    font-size: clamp(18px, 1.75vw, 24px);\n    line-height: 1.28;\n    font-weight: 750;\n    letter-spacing: -0.025em;\n  }\n\n  .dog-shoe-super__pain-box {\n    max-width: 535px;\n    margin-top: 22px;\n    padding: 16px 18px;\n    border-radius: 18px;\n    background: #ffffff;\n    border: 2px solid var(--orange);\n    box-shadow: 0 12px 30px rgba(255, 90, 0, 0.1);\n  }\n\n  .dog-shoe-super__pain-box strong {\n    display: block;\n    color: var(--black);\n    font-size: 19px;\n    line-height: 1.15;\n    font-weight: 950;\n    letter-spacing: -0.025em;\n  }\n\n  .dog-shoe-super__pain-box span {\n    display: block;\n    margin-top: 6px;\n    color: var(--muted);\n    font-size: 14px;\n    line-height: 1.3;\n    font-weight: 700;\n  }\n\n  .dog-shoe-super__benefits {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 10px;\n    max-width: 535px;\n    margin-top: 22px;\n  }\n\n  .dog-shoe-super__benefits div {\n    min-height: 56px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 7px;\n    padding: 12px 8px;\n    border-radius: 14px;\n    background: var(--soft);\n    border: 1px solid var(--border);\n    color: var(--black);\n    text-align: center;\n    font-size: 15px;\n    line-height: 1.1;\n    font-weight: 900;\n    letter-spacing: -0.02em;\n  }\n\n  .dog-shoe-super__benefits span {\n    color: var(--orange);\n    font-size: 17px;\n    font-weight: 950;\n  }\n\n  .dog-shoe-super__cta-wrap {\n    margin-top: 28px;\n  }\n\n  .dog-shoe-super__cta {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    gap: 14px;\n    min-width: 250px;\n    padding: 20px 36px;\n    border-radius: 16px;\n    background: var(--orange);\n    color: #ffffff;\n    text-decoration: none;\n    font-size: 23px;\n    line-height: 1;\n    font-weight: 950;\n    letter-spacing: -0.035em;\n    text-transform: uppercase;\n    box-shadow: 0 8px 0 var(--orange-dark);\n    transition: transform 0.16s ease, box-shadow 0.16s ease;\n  }\n\n  .dog-shoe-super__cta:hover {\n    transform: translateY(4px);\n    box-shadow: 0 4px 0 var(--orange-dark);\n  }\n\n  .dog-shoe-super__cta span {\n    font-size: 27px;\n    line-height: 0.7;\n  }\n\n  .dog-shoe-super__under-cta {\n    margin-top: 15px;\n    color: var(--muted);\n    font-size: 13px;\n    line-height: 1.3;\n    font-weight: 750;\n  }\n\n  .dog-shoe-super__visual {\n    position: relative;\n    width: 100%;\n    max-width: 585px;\n    margin-left: auto;\n    padding: 16px;\n  }\n\n  .dog-shoe-super__visual::before {\n    content: \"\";\n    position: absolute;\n    inset: 34px 0 20px 28px;\n    border-radius: 34px;\n    background: linear-gradient(135deg, #fff1e8, #ffffff);\n    border: 1px solid var(--border);\n  }\n\n  .dog-shoe-super__media {\n    position: relative;\n    z-index: 1;\n    width: 100%;\n    min-height: 455px;\n    border-radius: 28px;\n    overflow: hidden;\n    background: #ffffff;\n    border: 1px solid var(--border);\n    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.08);\n  }\n\n  .dog-shoe-super__media img {\n    width: 100%;\n    height: 100%;\n    min-height: 455px;\n    display: block;\n    object-fit: cover;\n    object-position: center;\n  }\n\n  .dog-shoe-super__floating-badge {\n    position: absolute;\n    z-index: 3;\n    padding: 11px 14px;\n    border-radius: 16px;\n    background: #ffffff;\n    border: 1px solid var(--border);\n    box-shadow: 0 14px 35px rgba(0, 0, 0, 0.11);\n  }\n\n  .dog-shoe-super__floating-badge strong {\n    display: block;\n    color: var(--black);\n    font-size: 15px;\n    line-height: 1;\n    font-weight: 950;\n    text-transform: uppercase;\n    letter-spacing: -0.02em;\n  }\n\n  .dog-shoe-super__floating-badge span {\n    display: block;\n    margin-top: 5px;\n    color: var(--orange);\n    font-size: 12px;\n    line-height: 1;\n    font-weight: 850;\n    text-transform: uppercase;\n  }\n\n  .dog-shoe-super__floating-badge--top {\n    top: 0;\n    left: 0;\n  }\n\n  .dog-shoe-super__floating-badge--bottom {\n    right: 0;\n    bottom: 0;\n  }\n\n  @media screen and (max-width: 990px) {\n    .dog-shoe-super {\n      padding: 44px 14px;\n    }\n\n    .dog-shoe-super__inner {\n      grid-template-columns: 1fr;\n      max-width: 760px;\n      min-height: auto;\n      gap: 32px;\n      text-align: center;\n    }\n\n    .dog-shoe-super__copy {\n      max-width: none;\n      margin: 0 auto;\n    }\n\n    .dog-shoe-super__subtitle,\n    .dog-shoe-super__pain-box,\n    .dog-shoe-super__benefits {\n      margin-left: auto;\n      margin-right: auto;\n    }\n\n    .dog-shoe-super__visual {\n      max-width: 620px;\n      margin: 0 auto;\n    }\n\n    .dog-shoe-super__media,\n    .dog-shoe-super__media img {\n      min-height: 430px;\n    }\n  }\n\n  @media screen and (max-width: 560px) {\n    .dog-shoe-super {\n      padding: 32px 10px;\n    }\n\n    .dog-shoe-super__proof-line {\n      font-size: 11px;\n      padding: 8px 11px;\n      margin-bottom: 14px;\n    }\n\n    .dog-shoe-super__title {\n      line-height: 0.94;\n      letter-spacing: -0.05em;\n    }\n\n    .dog-shoe-super__title span,\n    .dog-shoe-super__title strong {\n      font-size: clamp(42px, 12.3vw, 58px);\n    }\n\n    .dog-shoe-super__subtitle {\n      max-width: 350px;\n      margin-top: 16px;\n      font-size: 16px;\n      line-height: 1.32;\n    }\n\n    .dog-shoe-super__pain-box {\n      margin-top: 18px;\n      padding: 13px 14px;\n      border-radius: 15px;\n    }\n\n    .dog-shoe-super__pain-box strong {\n      font-size: 15px;\n    }\n\n    .dog-shoe-super__pain-box span {\n      font-size: 12px;\n    }\n\n    .dog-shoe-super__benefits {\n      grid-template-columns: repeat(3, 1fr);\n      gap: 6px;\n      margin-top: 18px;\n    }\n\n    .dog-shoe-super__benefits div {\n      min-height: 48px;\n      gap: 3px;\n      padding: 10px 4px;\n      border-radius: 12px;\n      font-size: 10.5px;\n      line-height: 1.12;\n      flex-direction: column;\n    }\n\n    .dog-shoe-super__benefits span {\n      font-size: 13px;\n    }\n\n    .dog-shoe-super__cta-wrap {\n      margin-top: 22px;\n    }\n\n    .dog-shoe-super__cta {\n      width: 100%;\n      min-width: 0;\n      padding: 18px 24px;\n      font-size: 21px;\n      border-radius: 14px;\n    }\n\n    .dog-shoe-super__under-cta {\n      margin-top: 14px;\n      font-size: 11px;\n    }\n\n    .dog-shoe-super__visual {\n      padding: 10px;\n    }\n\n    .dog-shoe-super__visual::before {\n      inset: 24px 0 14px 18px;\n      border-radius: 24px;\n    }\n\n    .dog-shoe-super__media,\n    .dog-shoe-super__media img {\n      min-height: 320px;\n    }\n\n    .dog-shoe-super__media {\n      border-radius: 18px;\n    }\n\n    .dog-shoe-super__floating-badge {\n      padding: 8px 10px;\n      border-radius: 12px;\n    }\n\n    .dog-shoe-super__floating-badge strong {\n      font-size: 11px;\n    }\n\n    .dog-shoe-super__floating-badge span {\n      font-size: 9px;\n      margin-top: 4px;\n    }\n  }\n\n  @media screen and (max-width: 380px) {\n    .dog-shoe-super__title span,\n    .dog-shoe-super__title strong {\n      font-size: 40px;\n    }\n\n    .dog-shoe-super__benefits div {\n      font-size: 9.5px;\n    }\n\n    .dog-shoe-super__media,\n    .dog-shoe-super__media img {\n      min-height: 295px;\n    }\n  }\n</style>",
