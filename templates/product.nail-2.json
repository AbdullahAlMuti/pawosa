        "custom_liquid": "<div class=\"tl-sell-section\">\n  <div class=\"tl-sell-section__inner\">\n\n    <div class=\"tl-sell-section__header\">\n      <div class=\"tl-sell-section__pill\">Best Seller • Twist-Lock Dog Shoes</div>\n\n      <h2 class=\"tl-sell-section__title\">\n        Dog Shoes That\n        <span>Actually Stay On.</span>\n      </h2>\n    </div>\n\n    <div class=\"tl-sell-section__proof\">\n      <div class=\"tl-sell-section__proof-item\">\n        <strong>✓ No More Lost Shoes</strong>\n        <span>Twist-lock fit helps keep shoes secure during real walks.</span>\n      </div>\n\n      <div class=\"tl-sell-section__proof-item\">\n        <strong>✓ On In Seconds</strong>\n        <span>No annoying straps. Just place, twist, and go.</span>\n      </div>\n\n      <div class=\"tl-sell-section__proof-item\">\n        <strong>✓ Protects Paws</strong>\n        <span>Helps shield paws from heat, cold, dirt, rocks, and rough paths.</span>\n      </div>\n    </div>\n\n    <div class=\"tl-sell-section__image-card\">\n      <img\n        src=\"https://cdn.shopify.com/s/files/1/0813/4626/5347/files/shoe_tie_process.webp?v=1779110281\"\n        alt=\"How the twist lock dog shoe system works\"\n        class=\"tl-sell-section__image\"\n        loading=\"eager\"\n        fetchpriority=\"high\"\n        decoding=\"async\"\n        width=\"1800\"\n        height=\"560\"\n      >\n    </div>\n\n    <div class=\"tl-sell-section__bottom\">\n      <div class=\"tl-sell-section__review\">\n        <div class=\"tl-sell-section__stars\">★★★★★</div>\n        <strong>“Finally, dog shoes that stay on.”</strong>\n        <span>Loved by dog parents who are tired of loose, slipping, kicked-off shoes.</span>\n      </div>\n\n      <a href=\"https://pawosa.com/checkouts/cn/hWNCIoxPFum1rmmds947WLlU\" class=\"tl-sell-section__cta\">\n        Shop Twist-Lock Shoes\n        <span>→</span>\n      </a>\n\n      <div class=\"tl-sell-section__offer\">\n        <strong>Protect Their Paws Today</strong>\n        <span>Comfortable fit. Secure hold. Ready for everyday walks.</span>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<style>\n  .tl-sell-section {\n    --orange: #ff4f00;\n    --orange-dark: #d94300;\n    --black: #070707;\n    --gray: #4b4b4b;\n    --light: #ffffff;\n    --border: #eeeeee;\n\n    width: 100%;\n    background: #ffffff;\n    padding: clamp(38px, 5vw, 72px) clamp(10px, 3vw, 22px);\n    overflow: hidden;\n    font-family: Arial, Helvetica, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    text-rendering: geometricPrecision;\n  }\n\n  .tl-sell-section * {\n    box-sizing: border-box;\n  }\n\n  .tl-sell-section__inner {\n    width: 100%;\n    max-width: 1220px;\n    margin: 0 auto;\n  }\n\n  .tl-sell-section__header {\n    max-width: 950px;\n    margin: 0 auto 28px;\n    text-align: center;\n  }\n\n  .tl-sell-section__pill {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    margin-bottom: 14px;\n    padding: 10px 18px;\n    border-radius: 999px;\n    background: var(--orange);\n    color: #ffffff;\n    font-size: 13px;\n    line-height: 1;\n    font-weight: 950;\n    letter-spacing: 0.09em;\n    text-transform: uppercase;\n  }\n\n  .tl-sell-section__title {\n    margin: 0;\n    color: var(--black);\n    font-size: clamp(46px, 6.4vw, 92px);\n    line-height: 0.9;\n    font-weight: 950;\n    letter-spacing: -0.065em;\n    text-transform: uppercase;\n  }\n\n  .tl-sell-section__title span {\n    color: var(--orange);\n    display: block;\n  }\n\n  .tl-sell-section__proof {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 14px;\n    width: 100%;\n    margin: 0 auto 22px;\n  }\n\n  .tl-sell-section__proof-item {\n    min-height: 116px;\n    padding: 22px 18px;\n    border-radius: 20px;\n    background: #ffffff;\n    border: 1px solid var(--border);\n    text-align: center;\n  }\n\n  .tl-sell-section__proof-item strong {\n    display: block;\n    color: var(--black);\n    font-size: 19px;\n    line-height: 1.05;\n    font-weight: 950;\n    text-transform: uppercase;\n    letter-spacing: -0.03em;\n  }\n\n  .tl-sell-section__proof-item span {\n    display: block;\n    max-width: 290px;\n    margin: 9px auto 0;\n    color: var(--gray);\n    font-size: 14px;\n    line-height: 1.3;\n    font-weight: 700;\n  }\n\n  .tl-sell-section__image-card {\n    position: relative;\n    width: 100%;\n    border-radius: 0;\n    overflow: hidden;\n    background: #ffffff;\n    border: 0;\n  }\n\n  .tl-sell-section__image {\n    width: 100%;\n    max-width: 100%;\n    height: auto;\n    display: block;\n  }\n\n  .tl-sell-section__bottom {\n    display: grid;\n    grid-template-columns: 1fr auto 1fr;\n    align-items: center;\n    gap: 18px;\n    width: 100%;\n    margin-top: 24px;\n    padding: 20px 0;\n    border-radius: 0;\n    background: #ffffff;\n    border: 0;\n  }\n\n  .tl-sell-section__review {\n    text-align: left;\n  }\n\n  .tl-sell-section__stars {\n    color: var(--orange);\n    font-size: 18px;\n    line-height: 1;\n    letter-spacing: 0.08em;\n    font-weight: 900;\n    margin-bottom: 7px;\n  }\n\n  .tl-sell-section__review strong,\n  .tl-sell-section__offer strong {\n    display: block;\n    color: var(--black);\n    font-size: 18px;\n    line-height: 1.12;\n    font-weight: 950;\n    letter-spacing: -0.025em;\n    text-transform: uppercase;\n  }\n\n  .tl-sell-section__review span,\n  .tl-sell-section__offer span {\n    display: block;\n    margin-top: 6px;\n    color: var(--gray);\n    font-size: 14px;\n    line-height: 1.28;\n    font-weight: 700;\n  }\n\n  .tl-sell-section__cta {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    gap: 14px;\n    min-width: 265px;\n    padding: 19px 32px;\n    border-radius: 14px;\n    background: var(--orange);\n    color: #ffffff;\n    text-decoration: none;\n    font-size: 21px;\n    line-height: 1;\n    font-weight: 950;\n    letter-spacing: -0.035em;\n    text-transform: uppercase;\n    border: 0;\n    transition: background 0.16s ease, transform 0.16s ease;\n  }\n\n  .tl-sell-section__cta:hover {\n    background: var(--orange-dark);\n    transform: translateY(-1px);\n  }\n\n  .tl-sell-section__cta span {\n    font-size: 25px;\n  }\n\n  .tl-sell-section__offer {\n    text-align: right;\n  }\n\n  @media screen and (max-width: 749px) {\n    .tl-sell-section {\n      padding: 36px 10px;\n      background: #ffffff;\n    }\n\n    .tl-sell-section__header {\n      margin-bottom: 20px;\n    }\n\n    .tl-sell-section__pill {\n      font-size: 10px;\n      padding: 8px 13px;\n      margin-bottom: 12px;\n    }\n\n    .tl-sell-section__title {\n      font-size: clamp(38px, 11vw, 52px);\n      line-height: 0.92;\n      letter-spacing: -0.05em;\n    }\n\n    .tl-sell-section__proof {\n      grid-template-columns: 1fr;\n      gap: 9px;\n      margin: 0 auto 15px;\n    }\n\n    .tl-sell-section__proof-item {\n      min-height: auto;\n      padding: 15px 14px;\n      border-radius: 14px;\n      background: #ffffff;\n      border: 1px solid var(--border);\n      text-align: left;\n    }\n\n    .tl-sell-section__proof-item strong {\n      font-size: 15px;\n      line-height: 1.1;\n    }\n\n    .tl-sell-section__proof-item span {\n      max-width: none;\n      margin-top: 6px;\n      font-size: 13px;\n      line-height: 1.25;\n    }\n\n    .tl-sell-section__image-card {\n      border-radius: 0;\n      border: 0;\n    }\n\n    .tl-sell-section__bottom {\n      grid-template-columns: 1fr;\n      gap: 14px;\n      margin-top: 16px;\n      padding: 15px 0 0;\n      border-radius: 0;\n      background: #ffffff;\n      text-align: center;\n    }\n\n    .tl-sell-section__review,\n    .tl-sell-section__offer {\n      text-align: center;\n    }\n\n    .tl-sell-section__stars {\n      font-size: 16px;\n    }\n\n    .tl-sell-section__review strong,\n    .tl-sell-section__offer strong {\n      font-size: 16px;\n    }\n\n    .tl-sell-section__review span,\n    .tl-sell-section__offer span {\n      font-size: 13px;\n    }\n\n    .tl-sell-section__cta {\n      width: 100%;\n      min-width: 0;\n      padding: 17px 20px;\n      font-size: 18px;\n      border-radius: 14px;\n    }\n  }\n\n  @media screen and (max-width: 420px) {\n    .tl-sell-section {\n      padding-left: 8px;\n      padding-right: 8px;\n    }\n\n    .tl-sell-section__title {\n      font-size: 38px;\n    }\n\n    .tl-sell-section__cta {\n      font-size: 16px;\n    }\n  }\n</style>",
