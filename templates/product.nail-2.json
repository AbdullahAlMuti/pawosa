    "custom_liquid_zkgqme": {
      "type": "custom-liquid",
      "name": "Reviews",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<section class=\"pawosa-testimonials\">\n  <div class=\"pt-head\">\n    <span>Why Dog Parents Choose Pawosa 🐾</span>\n    <h2>Built For Real Walks.</h2>\n    <p>Designed for dogs who need a secure shoe that protects paws without slipping, sliding, or getting kicked off.</p>\n  </div>\n\n  <div class=\"pt-wrap\">\n    <button class=\"pt-arrow pt-prev\" type=\"button\" aria-label=\"Previous benefits\">‹</button>\n\n    <div class=\"pt-carousel\">\n      <div class=\"pt-track\">\n\n        <article class=\"pt-card\">\n          <div class=\"pt-icon\">✓</div>\n          <h3>Stays On Better</h3>\n          <p>The twist-lock fit helps keep the shoes secure during walks, runs, and outdoor play.</p>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-icon\">✓</div>\n          <h3>No Loose Straps</h3>\n          <p>No messy velcro. Just twist to tighten and gently pull to loosen when the walk is done.</p>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-icon\">✓</div>\n          <h3>Hot Pavement Protection</h3>\n          <p>Helps protect sensitive paws from hot sidewalks, roads, and summer walking surfaces.</p>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-icon\">✓</div>\n          <h3>Cold Weather Ready</h3>\n          <p>Great for helping reduce direct contact with cold sidewalks, ice, dirt, and rough ground.</p>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-icon\">✓</div>\n          <h3>Fast To Put On</h3>\n          <p>The simple closure makes it easier to get all four shoes on before your dog gets impatient.</p>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-icon\">✓</div>\n          <h3>Cleaner Paws</h3>\n          <p>Helps keep paws cleaner after muddy paths, wet sidewalks, grass, and everyday outdoor walks.</p>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-icon\">✓</div>\n          <h3>Made For Daily Walks</h3>\n          <p>Lightweight, practical, and made for everyday use — not just occasional outdoor trips.</p>\n        </article>\n\n        <article class=\"pt-card\">\n          <div class=\"pt-icon\">✓</div>\n          <h3>Secure Adjustable Fit</h3>\n          <p>The twist system lets you adjust the fit more precisely than standard strap-style dog shoes.</p>\n        </article>\n\n      </div>\n    </div>\n\n    <button class=\"pt-arrow pt-next\" type=\"button\" aria-label=\"Next benefits\">›</button>\n  </div>\n</section>\n\n<style>\n  .pawosa-testimonials {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 34px 14px;\n    background: #ffffff;\n    font-family: Arial, Helvetica, sans-serif;\n    color: #070707;\n    overflow: hidden;\n  }\n\n  .pawosa-testimonials * {\n    box-sizing: border-box;\n  }\n\n  .pt-head {\n    text-align: center;\n    max-width: 720px;\n    margin: 0 auto 22px;\n  }\n\n  .pt-head span {\n    display: inline-block;\n    margin-bottom: 8px;\n    padding: 7px 13px;\n    border-radius: 999px;\n    background: #fff2eb;\n    color: #ff4f00;\n    font-size: 12px;\n    font-weight: 900;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n  }\n\n  .pt-head h2 {\n    margin: 0;\n    font-size: clamp(28px, 4vw, 46px);\n    line-height: 1.02;\n    font-weight: 950;\n    letter-spacing: -0.045em;\n    color: #070707;\n    text-transform: uppercase;\n  }\n\n  .pt-head p {\n    margin: 10px auto 0;\n    font-size: 15px;\n    line-height: 1.45;\n    color: #4b4b4b;\n    font-weight: 650;\n  }\n\n  .pt-wrap {\n    position: relative;\n  }\n\n  .pt-carousel {\n    overflow: hidden;\n  }\n\n  .pt-track {\n    display: flex;\n    gap: 10px;\n    transition: transform 0.35s ease;\n  }\n\n  .pt-card {\n    flex: 0 0 calc((100% - 50px) / 6);\n    min-width: calc((100% - 50px) / 6);\n    background: #ffffff;\n    border: 1px solid #eeeeee;\n    border-radius: 14px;\n    padding: 15px;\n  }\n\n  .pt-icon {\n    width: 28px;\n    height: 28px;\n    border-radius: 50%;\n    background: #ff4f00;\n    color: #ffffff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 15px;\n    line-height: 1;\n    font-weight: 950;\n    margin-bottom: 10px;\n  }\n\n  .pt-card h3 {\n    margin: 0 0 7px;\n    font-size: 15px;\n    line-height: 1.1;\n    font-weight: 950;\n    letter-spacing: -0.03em;\n    color: #070707;\n    text-transform: uppercase;\n  }\n\n  .pt-card p {\n    margin: 0;\n    min-height: 76px;\n    font-size: 13px;\n    line-height: 1.35;\n    font-weight: 650;\n    color: #4b4b4b;\n  }\n\n  .pt-arrow {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    z-index: 5;\n    width: 34px;\n    height: 34px;\n    border: 1px solid #eeeeee;\n    border-radius: 50%;\n    background: #ffffff;\n    color: #ff4f00;\n    font-size: 26px;\n    line-height: 1;\n    font-weight: 700;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .pt-prev {\n    left: -6px;\n  }\n\n  .pt-next {\n    right: -6px;\n  }\n\n  .pt-arrow.is-disabled {\n    opacity: 0.35;\n    cursor: not-allowed;\n  }\n\n  @media (max-width: 990px) {\n    .pt-card {\n      flex-basis: calc((100% - 20px) / 3);\n      min-width: calc((100% - 20px) / 3);\n    }\n  }\n\n  @media (max-width: 640px) {\n    .pawosa-testimonials {\n      padding: 30px 10px;\n    }\n\n    .pt-head {\n      margin-bottom: 18px;\n    }\n\n    .pt-head h2 {\n      font-size: 30px;\n    }\n\n    .pt-head p {\n      font-size: 14px;\n    }\n\n    .pt-card {\n      flex-basis: calc((100% - 10px) / 2);\n      min-width: calc((100% - 10px) / 2);\n      padding: 13px;\n    }\n\n    .pt-card h3 {\n      font-size: 14px;\n    }\n\n    .pt-card p {\n      font-size: 12.5px;\n      min-height: 76px;\n    }\n\n    .pt-arrow {\n      width: 30px;\n      height: 30px;\n      font-size: 22px;\n    }\n\n    .pt-prev {\n      left: 0;\n    }\n\n    .pt-next {\n      right: 0;\n    }\n  }\n\n  @media (max-width: 420px) {\n    .pt-card {\n      flex-basis: 100%;\n      min-width: 100%;\n    }\n\n    .pt-card p {\n      min-height: auto;\n    }\n  }\n</style>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    document.querySelectorAll(\".pawosa-testimonials\").forEach(function (section) {\n      const track = section.querySelector(\".pt-track\");\n      const cards = section.querySelectorAll(\".pt-card\");\n      const prev = section.querySelector(\".pt-prev\");\n      const next = section.querySelector(\".pt-next\");\n      let index = 0;\n\n      function visibleCards() {\n        if (window.innerWidth <= 420) return 1;\n        if (window.innerWidth <= 640) return 2;\n        if (window.innerWidth <= 990) return 3;\n        return 6;\n      }\n\n      function update() {\n        const gap = 10;\n        const visible = visibleCards();\n        const max = Math.max(cards.length - visible, 0);\n        const step = cards[0].offsetWidth + gap;\n\n        if (index > max) index = max;\n\n        track.style.transform = \"translateX(-\" + index * step + \"px)\";\n        prev.classList.toggle(\"is-disabled\", index === 0);\n        next.classList.toggle(\"is-disabled\", index === max);\n      }\n\n      next.addEventListener(\"click\", function () {\n        const max = Math.max(cards.length - visibleCards(), 0);\n        if (index < max) {\n          index++;\n          update();\n        }\n      });\n\n      prev.addEventListener(\"click\", function () {\n        if (index > 0) {\n          index--;\n          update();\n        }\n      });\n\n      window.addEventListener(\"resize\", update);\n      update();\n    });\n  });\n</script>",
        "color_scheme": "background-1",
