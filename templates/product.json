    "custom_liquid_eJzq4k": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<style>\n  #ncf-block {\n    --cream:      #f5f1ea;\n    --cream-dark: #eceae3;\n    --forest:     #1b3329;\n    --orange:     #e8621a;\n    --orange-glow:#ff7a30;\n    --check:      #2a5e3f;\n    --text:       #111111;\n    --muted:      #666666;\n    --radius:     18px;\n    --card-shadow: 0 2px 12px rgba(0,0,0,.06), 0 8px 32px rgba(0,0,0,.07);\n    background: var(--cream);\n    padding: 72px 24px 80px;\n    overflow: hidden;\n    font-family: 'Georgia', 'Times New Roman', serif;\n  }\n  #ncf-block * { box-sizing: border-box; }\n  #ncf-block .ncf__inner {\n    max-width: 1160px;\n    margin: 0 auto;\n  }\n\n  /* Headline */\n  #ncf-block .ncf__headline {\n    text-align: center;\n    margin-bottom: 52px;\n  }\n  #ncf-block .ncf__headline h2 {\n    font-size: clamp(28px, 4.5vw, 46px);\n    font-weight: 700;\n    color: var(--text);\n    letter-spacing: -0.8px;\n    line-height: 1.15;\n    margin: 0;\n  }\n  #ncf-block .ncf__headline h2 em {\n    font-style: normal;\n    color: var(--orange);\n  }\n  #ncf-block .ncf__headline .ncf__sub {\n    margin: 14px auto 0;\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    font-size: 15px;\n    color: var(--muted);\n    max-width: 480px;\n    line-height: 1.6;\n  }\n\n  /* Layout */\n  #ncf-block .ncf__row {\n    display: grid;\n    grid-template-columns: 1fr auto 1fr;\n    align-items: center;\n    gap: 0 28px;\n  }\n\n  /* Pain Cards */\n  #ncf-block .ncf__pain-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 14px;\n  }\n  #ncf-block .ncf__pain-card {\n    background: #fff;\n    border-radius: var(--radius);\n    overflow: hidden;\n    box-shadow: var(--card-shadow);\n    display: flex;\n    flex-direction: column;\n    transition: transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s ease;\n    border: 1px solid rgba(0,0,0,.04);\n  }\n  #ncf-block .ncf__pain-card:hover {\n    transform: translateY(-6px);\n    box-shadow: 0 4px 20px rgba(0,0,0,.08), 0 20px 60px rgba(0,0,0,.10);\n  }\n  #ncf-block .ncf__pain-img {\n    position: relative;\n    aspect-ratio: 1 / 1;\n    overflow: hidden;\n    background: linear-gradient(145deg, #ccc 0%, #aaa 100%);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 44px;\n  }\n  #ncf-block .ncf__pain-img img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    transition: transform .5s ease;\n  }\n  #ncf-block .ncf__pain-card:hover .ncf__pain-img img {\n    transform: scale(1.04);\n  }\n  #ncf-block .ncf__pain-badge {\n    position: absolute;\n    bottom: 10px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: #c0392b;\n    border-radius: 50%;\n    width: 30px;\n    height: 30px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: 0 4px 12px rgba(192,57,43,.5);\n    border: 2px solid #fff;\n  }\n  #ncf-block .ncf__pain-label {\n    padding: 14px 12px 16px;\n    text-align: center;\n  }\n  #ncf-block .ncf__pain-label strong {\n    display: block;\n    font-size: 13px;\n    font-weight: 700;\n    color: var(--text);\n    line-height: 1.3;\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n  }\n  #ncf-block .ncf__pain-label span {\n    font-size: 11.5px;\n    color: var(--muted);\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    line-height: 1.4;\n    margin-top: 3px;\n    display: block;\n  }\n\n  /* Arrow */\n  #ncf-block .ncf__arrow {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  #ncf-block .ncf__arrow-circle {\n    width: 52px;\n    height: 52px;\n    border-radius: 50%;\n    background: var(--orange);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: 0 4px 16px rgba(232,98,26,.35), 0 0 0 0 rgba(232,98,26,.25);\n    animation: ncf-arrow-pulse 2.2s ease-in-out infinite, ncf-arrow-slide 2.2s ease-in-out infinite;\n    flex-shrink: 0;\n    position: relative;\n  }\n  @keyframes ncf-arrow-slide {\n    0%   { transform: translateX(-5px); }\n    50%  { transform: translateX(5px); }\n    100% { transform: translateX(-5px); }\n  }\n  @keyframes ncf-arrow-pulse {\n    0%   { box-shadow: 0 4px 16px rgba(232,98,26,.35), 0 0 0 0 rgba(232,98,26,.25); }\n    50%  { box-shadow: 0 4px 16px rgba(232,98,26,.35), 0 0 0 10px rgba(232,98,26,.0); }\n    100% { box-shadow: 0 4px 16px rgba(232,98,26,.35), 0 0 0 0 rgba(232,98,26,.0); }\n  }\n\n  /* Solution Card */\n  #ncf-block .ncf__solution {\n    background: var(--cream-dark);\n    border-radius: var(--radius);\n    overflow: hidden;\n    box-shadow: var(--card-shadow);\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    min-height: 280px;\n    border: 1px solid rgba(0,0,0,.05);\n  }\n  #ncf-block .ncf__solution-text {\n    padding: 40px 32px;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n  }\n  #ncf-block .ncf__solution-eyebrow {\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 1.8px;\n    text-transform: uppercase;\n    color: var(--orange);\n    margin: 0 0 10px;\n  }\n  #ncf-block .ncf__solution-text h3 {\n    font-size: clamp(18px, 2.4vw, 26px);\n    font-weight: 700;\n    color: var(--text);\n    margin: 0 0 12px;\n    line-height: 1.2;\n    letter-spacing: -0.4px;\n  }\n  #ncf-block .ncf__solution-text p {\n    font-size: 14px;\n    color: var(--muted);\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    line-height: 1.7;\n    margin: 0 0 22px;\n  }\n  #ncf-block .ncf__benefits {\n    list-style: none;\n    margin: 0;\n    padding: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  #ncf-block .ncf__benefits li {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    font-size: 13.5px;\n    font-weight: 600;\n    color: var(--text);\n  }\n  #ncf-block .ncf__check-icon {\n    width: 20px;\n    height: 20px;\n    border-radius: 50%;\n    background: var(--check);\n    flex-shrink: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: 0 2px 6px rgba(42,94,63,.3);\n  }\n  #ncf-block .ncf__solution-img {\n    overflow: hidden;\n    background: linear-gradient(160deg, #b5c9b8 0%, #7a9e7e 100%);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 64px;\n    position: relative;\n  }\n  #ncf-block .ncf__solution-img img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    transition: transform .6s ease;\n  }\n  #ncf-block .ncf__solution:hover .ncf__solution-img img {\n    transform: scale(1.03);\n  }\n\n  /* Responsive */\n  @media (max-width: 940px) {\n    #ncf-block .ncf__row {\n      grid-template-columns: 1fr;\n      gap: 24px 0;\n    }\n    #ncf-block .ncf__arrow {\n      transform: rotate(90deg);\n    }\n    #ncf-block .ncf__solution {\n      grid-template-columns: 1fr;\n    }\n    #ncf-block .ncf__solution-img {\n      min-height: 200px;\n      order: -1;\n    }\n  }\n  @media (max-width: 600px) {\n    #ncf-block {\n      padding: 48px 16px 56px;\n    }\n    #ncf-block .ncf__pain-grid {\n      gap: 10px;\n    }\n    #ncf-block .ncf__solution-text {\n      padding: 28px 22px;\n    }\n    #ncf-block .ncf__arrow {\n      transform: rotate(90deg) scale(0.85);\n    }\n  }\n</style>\n\n<div id=\"ncf-block\">\n  <div class=\"ncf__inner\">\n\n    <!-- Headline -->\n    <div class=\"ncf__headline\">\n      <h2>Nail Trimming Can Be <em>Scary...</em></h2>\n      <p class=\"ncf__sub\">Most pet owners dread it. Here's why — and how we fixed it.</p>\n    </div>\n\n    <!-- Row -->\n    <div class=\"ncf__row\">\n\n      <!-- Pain Cards -->\n      <div class=\"ncf__pain-grid\">\n\n        <!-- Card 1 -->\n        <div class=\"ncf__pain-card\">\n          <div class=\"ncf__pain-img\">\n            🩸\n            <!-- REPLACE: <img src=\"{{ 'pain-1.jpg' | asset_url }}\" alt=\"Accidental cuts\"> -->\n            <div class=\"ncf__pain-badge\">\n              <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 2L10 10M10 2L2 10\" stroke=\"#fff\" stroke-width=\"2.2\" stroke-linecap=\"round\"/></svg>\n            </div>\n          </div>\n          <div class=\"ncf__pain-label\">\n            <strong>Accidental cuts</strong>\n            <span>cause pain & bleeding</span>\n          </div>\n        </div>\n\n        <!-- Card 2 -->\n        <div class=\"ncf__pain-card\">\n          <div class=\"ncf__pain-img\">\n            😰\n            <!-- REPLACE: <img src=\"{{ 'pain-2.jpg' | asset_url }}\" alt=\"Anxious pet\"> -->\n            <div class=\"ncf__pain-badge\">\n              <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 2L10 10M10 2L2 10\" stroke=\"#fff\" stroke-width=\"2.2\" stroke-linecap=\"round\"/></svg>\n            </div>\n          </div>\n          <div class=\"ncf__pain-label\">\n            <strong>Pets get anxious</strong>\n            <span>and resistant</span>\n          </div>\n        </div>\n\n        <!-- Card 3 -->\n        <div class=\"ncf__pain-card\">\n          <div class=\"ncf__pain-img\">\n            💸\n            <!-- REPLACE: <img src=\"{{ 'pain-3.jpg' | asset_url }}\" alt=\"Expensive grooming\"> -->\n            <div class=\"ncf__pain-badge\">\n              <svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 2L10 10M10 2L2 10\" stroke=\"#fff\" stroke-width=\"2.2\" stroke-linecap=\"round\"/></svg>\n            </div>\n          </div>\n          <div class=\"ncf__pain-label\">\n            <strong>Expensive grooming</strong>\n            <span>visits add up fast</span>\n          </div>\n        </div>\n\n      </div>\n\n      <!-- Animated Orange Arrow -->\n      <div class=\"ncf__arrow\">\n        <div class=\"ncf__arrow-circle\">\n          <svg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" fill=\"none\">\n            <path d=\"M4 11H18M12 5L18 11L12 17\" stroke=\"#fff\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </div>\n      </div>\n\n      <!-- Solution -->\n      <div class=\"ncf__solution\">\n        <div class=\"ncf__solution-text\">\n          <p class=\"ncf__solution-eyebrow\">The Solution</p>\n          <h3>But it Doesn't Have to Be.</h3>\n          <p>Our LED Pet Nail Clipper lets you see the quick clearly — trim safely, confidently, at home. No vet visits. No stress.</p>\n          <ul class=\"ncf__benefits\">\n            <li>\n              <span class=\"ncf__check-icon\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"none\"><path d=\"M1.5 5.5L4 8L8.5 2.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n              See Exactly Where to Cut\n            </li>\n            <li>\n              <span class=\"ncf__check-icon\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"none\"><path d=\"M1.5 5.5L4 8L8.5 2.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n              Prevent Painful Accidents\n            </li>\n            <li>\n              <span class=\"ncf__check-icon\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"none\"><path d=\"M1.5 5.5L4 8L8.5 2.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n              Keep Your Pet Calm & Happy\n            </li>\n            <li>\n              <span class=\"ncf__check-icon\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 10 10\" fill=\"none\"><path d=\"M1.5 5.5L4 8L8.5 2.5\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n              Safe, Easy & Stress-Free\n            </li>\n          </ul>\n        </div>\n        <div class=\"ncf__solution-img\">\n          ✂️\n          <!-- REPLACE: <img src=\"{{ 'product-hero.jpg' | asset_url }}\" alt=\"LED Pet Nail Clipper in use\"> -->\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>",
        "color_scheme": "background-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_zxhVct": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<style>\n  .pet-problem-banner {\n    padding: 40px 14px;\n    background: #ffffff;\n    font-family: Arial, Helvetica, sans-serif;\n  }\n\n  .pet-problem-wrap {\n    max-width: 1120px;\n    margin: 0 auto;\n  }\n\n  .pet-problem-header {\n    max-width: 720px;\n    margin: 0 auto 26px;\n    text-align: center;\n  }\n\n  .pet-problem-eyebrow {\n    margin: 0 0 10px;\n    font-size: 13px;\n    line-height: 1.2;\n    font-weight: 800;\n    letter-spacing: 0.8px;\n    text-transform: uppercase;\n    color: #1684e8;\n  }\n\n  .pet-problem-title {\n    margin: 0 0 10px;\n    font-size: clamp(27px, 4vw, 42px);\n    line-height: 1.08;\n    font-weight: 900;\n    color: #111827;\n    letter-spacing: -0.6px;\n  }\n\n  .pet-problem-title span {\n    color: #1684e8;\n  }\n\n  .pet-problem-subtitle {\n    margin: 0;\n    font-size: clamp(14px, 2vw, 17px);\n    line-height: 1.55;\n    font-weight: 500;\n    color: #4b5563;\n  }\n\n  .pet-problem-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: clamp(10px, 2vw, 16px);\n  }\n\n  .pet-problem-card {\n    background: #ffffff;\n    border: 1px solid #e5e7eb;\n    border-radius: 16px;\n    overflow: hidden;\n  }\n\n  .pet-problem-img-wrap {\n    position: relative;\n    background: #f5f7fb;\n  }\n\n  .pet-problem-card img {\n    width: 100%;\n    aspect-ratio: 1 / 0.9;\n    object-fit: cover;\n    display: block;\n  }\n\n  .pet-problem-label {\n    position: absolute;\n    left: 10px;\n    bottom: 10px;\n    padding: 6px 9px;\n    border-radius: 999px;\n    background: rgba(255, 255, 255, 0.92);\n    color: #111827;\n    font-size: 11.5px;\n    line-height: 1;\n    font-weight: 800;\n  }\n\n  .pet-problem-content {\n    padding: 14px 13px 15px;\n    text-align: left;\n  }\n\n  .pet-problem-text {\n    margin: 0 0 6px;\n    font-size: clamp(14px, 2vw, 16px);\n    line-height: 1.25;\n    font-weight: 850;\n    color: #111827;\n  }\n\n  .pet-problem-note {\n    margin: 0;\n    font-size: 12.5px;\n    line-height: 1.45;\n    font-weight: 500;\n    color: #6b7280;\n  }\n\n  .pet-brand-solution {\n    margin-top: 22px;\n    display: grid;\n    grid-template-columns: 1.15fr 0.85fr;\n    gap: 18px;\n    align-items: stretch;\n  }\n\n  .pet-brand-story {\n    padding: 20px;\n    border-radius: 18px;\n    background: #f3f8ff;\n    border: 1px solid #dbeaff;\n  }\n\n  .pet-brand-story-title {\n    margin: 0 0 8px;\n    font-size: clamp(19px, 2.5vw, 26px);\n    line-height: 1.18;\n    font-weight: 900;\n    color: #0f3f89;\n    letter-spacing: -0.4px;\n  }\n\n  .pet-brand-story-title span {\n    color: #1684e8;\n  }\n\n  .pet-brand-story-copy {\n    margin: 0;\n    font-size: 14.5px;\n    line-height: 1.6;\n    font-weight: 500;\n    color: #315c9b;\n  }\n\n  .pet-brand-points {\n    padding: 20px;\n    border-radius: 18px;\n    background: #ffffff;\n    border: 1px solid #e5e7eb;\n    display: grid;\n    gap: 11px;\n  }\n\n  .pet-brand-point {\n    display: grid;\n    grid-template-columns: 22px 1fr;\n    gap: 9px;\n    align-items: start;\n  }\n\n  .pet-brand-check {\n    width: 20px;\n    height: 20px;\n    border-radius: 50%;\n    background: #1684e8;\n    color: #ffffff;\n    font-size: 12px;\n    font-weight: 900;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-top: 1px;\n  }\n\n  .pet-brand-point strong {\n    display: block;\n    margin-bottom: 2px;\n    font-size: 13.5px;\n    line-height: 1.3;\n    font-weight: 850;\n    color: #111827;\n  }\n\n  .pet-brand-point span {\n    display: block;\n    font-size: 12.5px;\n    line-height: 1.4;\n    font-weight: 500;\n    color: #6b7280;\n  }\n\n  .pet-brand-trust {\n    margin-top: 16px;\n    padding-top: 14px;\n    border-top: 1px solid #e5e7eb;\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 8px;\n  }\n\n  .pet-brand-trust span {\n    font-size: 12.5px;\n    line-height: 1;\n    font-weight: 700;\n    color: #0b3f91;\n    background: #f3f8ff;\n    border-radius: 999px;\n    padding: 7px 10px;\n  }\n\n  @media (max-width: 768px) {\n    .pet-problem-banner {\n      padding: 34px 12px;\n    }\n\n    .pet-problem-header {\n      margin-bottom: 22px;\n    }\n\n    .pet-problem-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n\n    .pet-problem-card {\n      border-radius: 14px;\n    }\n\n    .pet-problem-content {\n      padding: 12px 11px 13px;\n    }\n\n    .pet-brand-solution {\n      grid-template-columns: 1fr;\n      gap: 12px;\n    }\n\n    .pet-brand-story,\n    .pet-brand-points {\n      padding: 16px;\n      border-radius: 16px;\n    }\n\n    .pet-brand-story-copy {\n      font-size: 13.8px;\n    }\n  }\n\n  @media (max-width: 380px) {\n    .pet-problem-grid {\n      gap: 10px;\n    }\n\n    .pet-problem-text {\n      font-size: 13.5px;\n    }\n\n    .pet-problem-note {\n      font-size: 11.7px;\n    }\n\n    .pet-brand-trust span {\n      font-size: 12px;\n      padding: 6px 9px;\n    }\n  }\n</style>\n\n<section class=\"pet-problem-banner\">\n  <div class=\"pet-problem-wrap\">\n\n    <div class=\"pet-problem-header\">\n      <p class=\"pet-problem-eyebrow\">Mealtime Enrichment</p>\n\n      <h2 class=\"pet-problem-title\">\n        Built for Pets Who Need <span>More Than a Bowl</span>\n      </h2>\n\n      <p class=\"pet-problem-subtitle\">\n        A simple enrichment feeder designed to make treat time slower, cleaner, and more engaging for everyday use.\n      </p>\n    </div>\n\n    <div class=\"pet-problem-grid\">\n      <div class=\"pet-problem-card\">\n        <div class=\"pet-problem-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/1_b6a9f306-d11d-4bb7-805e-bd8d79bbb544.png?v=1778179984\" alt=\"Dog eating too fast\">\n          <span class=\"pet-problem-label\">Fast eating</span>\n        </div>\n        <div class=\"pet-problem-content\">\n          <p class=\"pet-problem-text\">Encourages slower feeding</p>\n          <p class=\"pet-problem-note\">Helps pets work for their reward instead of finishing treats too quickly.</p>\n        </div>\n      </div>\n\n      <div class=\"pet-problem-card\">\n        <div class=\"pet-problem-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/2.png?v=1778179983\" alt=\"Pet making a mess while eating\">\n          <span class=\"pet-problem-label\">Messy snacks</span>\n        </div>\n        <div class=\"pet-problem-content\">\n          <p class=\"pet-problem-text\">Designed for cleaner treat time</p>\n          <p class=\"pet-problem-note\">Helps keep spreads and wet food more contained during play.</p>\n        </div>\n      </div>\n\n      <div class=\"pet-problem-card\">\n        <div class=\"pet-problem-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/3.png?v=1778179983\" alt=\"Pet getting bored easily\">\n          <span class=\"pet-problem-label\">Boredom</span>\n        </div>\n        <div class=\"pet-problem-content\">\n          <p class=\"pet-problem-text\">Adds mental stimulation</p>\n          <p class=\"pet-problem-note\">Turns favorite foods into a more interactive, longer-lasting activity.</p>\n        </div>\n      </div>\n\n      <div class=\"pet-problem-card\">\n        <div class=\"pet-problem-img-wrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/4.png?v=1778179983\" alt=\"Dog showing anxiety\">\n          <span class=\"pet-problem-label\">Restless pets</span>\n        </div>\n        <div class=\"pet-problem-content\">\n          <p class=\"pet-problem-text\">Keeps pets calmly engaged</p>\n          <p class=\"pet-problem-note\">Provides a focused reward-based activity during quiet time at home.</p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"pet-brand-solution\">\n      <div class=\"pet-brand-story\">\n        <h3 class=\"pet-brand-story-title\">\n          A better way to serve their <span>favorite treats.</span>\n        </h3>\n        <p class=\"pet-brand-story-copy\">\n          Fill it with yogurt, broth, peanut butter, or wet food. As your pet rolls and licks, snack time becomes a slower, more enriching routine that supports calmer behavior and cleaner feeding.\n        </p>\n\n        <div class=\"pet-brand-trust\">\n          <span>Food-grade material</span>\n          <span>Easy to clean</span>\n          <span>For dogs &amp; cats</span>\n        </div>\n      </div>\n\n      <div class=\"pet-brand-points\">\n        <div class=\"pet-brand-point\">\n          <span class=\"pet-brand-check\">✓</span>\n          <div>\n            <strong>Slow-feeding support</strong>\n            <span>Helps make treats last longer.</span>\n          </div>\n        </div>\n\n        <div class=\"pet-brand-point\">\n          <span class=\"pet-brand-check\">✓</span>\n          <div>\n            <strong>Daily enrichment</strong>\n            <span>Great for keeping pets occupied at home.</span>\n          </div>\n        </div>\n\n        <div class=\"pet-brand-point\">\n          <span class=\"pet-brand-check\">✓</span>\n          <div>\n            <strong>Rolling ball design</strong>\n            <span>Encourages natural curiosity and play.</span>\n          </div>\n        </div>\n\n        <div class=\"pet-brand-point\">\n          <span class=\"pet-brand-check\">✓</span>\n          <div>\n            <strong>Cleaner feeding</strong>\n            <span>Made to help reduce spills and mess.</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n</section>",
