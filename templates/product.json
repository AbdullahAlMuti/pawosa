    "custom_liquid_DjULRh": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<div class=\"rongora-ad-hiw\">\n  <div class=\"rongora-ad-hiw__inner\">\n\n    <div class=\"rongora-ad-hiw__eyebrow\">Easy to Use • Slow Feeding • Daily Enrichment</div>\n\n    <h2 class=\"rongora-ad-hiw__title\">\n      How Rongora <span>Works</span>\n    </h2>\n\n    <p class=\"rongora-ad-hiw__subtitle\">\n      Designed to make treat time slower, cleaner, and more engaging — without overcomplicating your pet’s routine.\n    </p>\n\n    <div class=\"rongora-ad-hiw__grid\">\n\n      <div class=\"rongora-ad-hiw__card\">\n        <div class=\"rongora-ad-hiw__num\">1</div>\n        <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/h1.png?v=1778180857\" alt=\"Adding treats into Rongora slow feeder\">\n        <h3>Add Their Favorite Treat</h3>\n        <p>Use yogurt, broth, puree, wet food, or soft frozen treats.</p>\n      </div>\n\n      <div class=\"rongora-ad-hiw__card\">\n        <div class=\"rongora-ad-hiw__num\">2</div>\n        <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/h2.png?v=1778180856\" alt=\"Rongora rolling ball slow release design\">\n        <h3>Rolling Ball Slows It Down</h3>\n        <p>The ball helps release treats gradually as your pet licks and plays.</p>\n      </div>\n\n      <div class=\"rongora-ad-hiw__card\">\n        <div class=\"rongora-ad-hiw__num\">3</div>\n        <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/h3.png?v=1778180857\" alt=\"Dog using Rongora slow feeder\">\n        <h3>They Stay Engaged Longer</h3>\n        <p>Helps turn quick snacks into a calmer, more focused activity.</p>\n      </div>\n\n      <div class=\"rongora-ad-hiw__card rongora-ad-hiw__card--feature\">\n        <div class=\"rongora-ad-hiw__label\">Thoughtful Design</div>\n        <img src=\"https://cdn.shopify.com/s/files/1/0964/9419/0939/files/h4.png?v=1778180857\" alt=\"Rongora slow feeder product design features\">\n        <div class=\"rongora-ad-hiw__chips\">\n          <span>Rolling Ball</span>\n          <span>Slow Release</span>\n          <span>Anti-Spill</span>\n        </div>\n      </div>\n\n    </div>\n\n  </div>\n</div>\n\n<style>\n  .rongora-ad-hiw {\n    background: #ffffff;\n    padding: clamp(38px, 6vw, 68px) 12px;\n    font-family: Poppins, Montserrat, Arial, sans-serif;\n    color: #061124;\n  }\n\n  .rongora-ad-hiw * {\n    box-sizing: border-box;\n  }\n\n  .rongora-ad-hiw__inner {\n    max-width: 1240px;\n    margin: 0 auto;\n  }\n\n  .rongora-ad-hiw__eyebrow {\n    width: fit-content;\n    margin: 0 auto 12px;\n    padding: 7px 14px;\n    border-radius: 999px;\n    background: #eef6ff;\n    color: #1376d8;\n    font-size: 12px;\n    font-weight: 800;\n    letter-spacing: .04em;\n    text-transform: uppercase;\n  }\n\n  .rongora-ad-hiw__title {\n    margin: 0;\n    text-align: center;\n    font-size: clamp(32px, 5.4vw, 58px);\n    font-weight: 900;\n    line-height: 1;\n    letter-spacing: -0.055em;\n    color: #061124;\n  }\n\n  .rongora-ad-hiw__title span {\n    color: #1684e8;\n  }\n\n  .rongora-ad-hiw__subtitle {\n    max-width: 650px;\n    margin: 14px auto 30px;\n    text-align: center;\n    color: #536176;\n    font-size: clamp(15px, 2vw, 18px);\n    line-height: 1.5;\n    font-weight: 500;\n  }\n\n  .rongora-ad-hiw__grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: clamp(12px, 2vw, 20px);\n  }\n\n  .rongora-ad-hiw__card {\n    position: relative;\n    background: #f7fbff;\n    border: 1px solid #d9edff;\n    border-radius: 22px;\n    padding: 16px 14px 20px;\n    text-align: center;\n    overflow: hidden;\n  }\n\n  .rongora-ad-hiw__card::before {\n    content: \"\";\n    position: absolute;\n    width: 130px;\n    height: 130px;\n    right: -58px;\n    top: -58px;\n    background: #e7f4ff;\n    border-radius: 50%;\n  }\n\n  .rongora-ad-hiw__num {\n    position: absolute;\n    top: 12px;\n    left: 12px;\n    width: 38px;\n    height: 38px;\n    border-radius: 50%;\n    background: #1684e8;\n    color: #ffffff;\n    border: 3px solid #ffffff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 18px;\n    font-weight: 900;\n    z-index: 2;\n  }\n\n  .rongora-ad-hiw__card img {\n    position: relative;\n    z-index: 1;\n    width: 100%;\n    height: 195px;\n    object-fit: contain;\n    display: block;\n    margin: 0 auto 10px;\n  }\n\n  .rongora-ad-hiw__card h3 {\n    position: relative;\n    z-index: 1;\n    margin: 0 0 8px;\n    font-size: clamp(16px, 1.6vw, 21px);\n    font-weight: 850;\n    line-height: 1.14;\n    letter-spacing: -0.035em;\n    color: #07152c;\n  }\n\n  .rongora-ad-hiw__card p {\n    position: relative;\n    z-index: 1;\n    max-width: 230px;\n    margin: 0 auto;\n    font-size: 14px;\n    line-height: 1.45;\n    color: #516071;\n    font-weight: 500;\n  }\n\n  .rongora-ad-hiw__label {\n    position: relative;\n    z-index: 2;\n    display: inline-flex;\n    padding: 7px 13px;\n    border-radius: 999px;\n    background: #1684e8;\n    color: #ffffff;\n    font-size: 12px;\n    font-weight: 850;\n    text-transform: uppercase;\n    letter-spacing: .04em;\n  }\n\n  .rongora-ad-hiw__chips {\n    position: relative;\n    z-index: 1;\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 7px;\n    margin-top: 6px;\n  }\n\n  .rongora-ad-hiw__chips span {\n    background: #ffffff;\n    border: 1px solid #bfe3ff;\n    color: #0a4f99;\n    border-radius: 999px;\n    padding: 7px 10px;\n    font-size: 12px;\n    font-weight: 800;\n  }\n\n  @media (max-width: 900px) {\n    .rongora-ad-hiw__grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media (max-width: 520px) {\n    .rongora-ad-hiw {\n      padding: 34px 10px;\n    }\n\n    .rongora-ad-hiw__eyebrow {\n      font-size: 10.5px;\n      padding: 6px 11px;\n      margin-bottom: 10px;\n    }\n\n    .rongora-ad-hiw__title {\n      font-size: clamp(30px, 10vw, 42px);\n    }\n\n    .rongora-ad-hiw__subtitle {\n      margin: 12px auto 22px;\n      font-size: 14px;\n      line-height: 1.45;\n    }\n\n    .rongora-ad-hiw__grid {\n      gap: 10px;\n    }\n\n    .rongora-ad-hiw__card {\n      border-radius: 18px;\n      padding: 10px 8px 15px;\n    }\n\n    .rongora-ad-hiw__num {\n      width: 32px;\n      height: 32px;\n      font-size: 16px;\n      border-width: 3px;\n      top: 8px;\n      left: 8px;\n    }\n\n    .rongora-ad-hiw__card img {\n      height: 128px;\n      margin-bottom: 8px;\n    }\n\n    .rongora-ad-hiw__card h3 {\n      font-size: 14px;\n      line-height: 1.15;\n    }\n\n    .rongora-ad-hiw__card p {\n      font-size: 11.5px;\n      line-height: 1.35;\n    }\n\n    .rongora-ad-hiw__label {\n      font-size: 10.5px;\n      padding: 6px 10px;\n    }\n\n    .rongora-ad-hiw__chips span {\n      font-size: 9.5px;\n      padding: 5px 7px;\n    }\n  }\n</style>",
