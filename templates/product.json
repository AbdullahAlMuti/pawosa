        "visibility": "always-display",
        "custom_liquid": "<div class=\"pawosa-bowl-compare\">\n  <style>\n    .pawosa-bowl-compare,\n    .pawosa-bowl-compare * {\n      box-sizing: border-box;\n    }\n\n    .pawosa-bowl-compare {\n      width: 100%;\n      padding: 30px 12px;\n      background: #ffffff;\n      font-family: Arial, Helvetica, sans-serif;\n      color: #08245c;\n    }\n\n    .pawosa-bowl-compare .pbc-shell {\n      max-width: 980px;\n      margin: 0 auto;\n    }\n\n    .pawosa-bowl-compare .pbc-heading {\n      margin: 0 0 8px;\n      text-align: center;\n      font-size: clamp(26px, 4vw, 42px);\n      line-height: 1.08;\n      font-weight: 900;\n      letter-spacing: -0.04em;\n      color: #08245c;\n    }\n\n    .pawosa-bowl-compare .pbc-heading span {\n      color: #135ff0;\n    }\n\n    .pawosa-bowl-compare .pbc-subheading {\n      max-width: 620px;\n      margin: 0 auto 18px;\n      text-align: center;\n      font-size: 15px;\n      line-height: 1.45;\n      font-weight: 500;\n      color: #51627a;\n    }\n\n    .pawosa-bowl-compare .pbc-table-wrap {\n      border: 1px solid #d9e7ff;\n      border-radius: 18px;\n      overflow: hidden;\n      background: #ffffff;\n    }\n\n    .pawosa-bowl-compare .pbc-table {\n      display: grid;\n      grid-template-columns: 1.12fr 0.82fr 0.82fr;\n    }\n\n    .pawosa-bowl-compare .pbc-cell {\n      min-height: 52px;\n      display: flex;\n      align-items: center;\n      padding: 11px 14px;\n      border-bottom: 1px solid #d9e7ff;\n      font-size: 14px;\n      line-height: 1.2;\n      font-weight: 800;\n    }\n\n    .pawosa-bowl-compare .pbc-cell:nth-last-child(-n + 3) {\n      border-bottom: 0;\n    }\n\n    .pawosa-bowl-compare .pbc-feature {\n      justify-content: flex-start;\n      background: #ffffff;\n      color: #0d2240;\n    }\n\n    .pawosa-bowl-compare .pbc-brand,\n    .pawosa-bowl-compare .pbc-basic {\n      justify-content: center;\n      text-align: left;\n      border-left: 1px solid #d9e7ff;\n    }\n\n    .pawosa-bowl-compare .pbc-brand {\n      background: #f2f7ff;\n      color: #135ff0;\n    }\n\n    .pawosa-bowl-compare .pbc-basic {\n      background: #f8fafc;\n      color: #7f8da3;\n    }\n\n    .pawosa-bowl-compare .pbc-top {\n      min-height: 48px;\n      justify-content: center;\n      text-align: center;\n      font-size: 13px;\n      text-transform: uppercase;\n      letter-spacing: 0.04em;\n      font-weight: 900;\n    }\n\n    .pawosa-bowl-compare .pbc-top-feature {\n      justify-content: flex-start;\n    }\n\n    .pawosa-bowl-compare .pbc-top-brand {\n      background: #135ff0;\n      color: #ffffff;\n    }\n\n    .pawosa-bowl-compare .pbc-top-basic {\n      background: #94a3b8;\n      color: #ffffff;\n    }\n\n    .pawosa-bowl-compare .pbc-choice {\n      width: 92px;\n      display: grid;\n      grid-template-columns: 23px 1fr;\n      align-items: center;\n      column-gap: 7px;\n      white-space: nowrap;\n    }\n\n    .pawosa-bowl-compare .pbc-mark {\n      width: 23px;\n      height: 23px;\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      border-radius: 999px;\n      font-size: 12px;\n      font-weight: 900;\n      line-height: 1;\n    }\n\n    .pawosa-bowl-compare .pbc-mark-good {\n      background: #135ff0;\n      color: #ffffff;\n    }\n\n    .pawosa-bowl-compare .pbc-mark-bad {\n      background: #b8c2d1;\n      color: #ffffff;\n    }\n\n    .pawosa-bowl-compare .pbc-choice span:last-child {\n      font-size: 14px;\n      font-weight: 900;\n      line-height: 1;\n    }\n\n    @media (max-width: 640px) {\n      .pawosa-bowl-compare {\n        padding: 28px 10px;\n      }\n\n      .pawosa-bowl-compare .pbc-heading {\n        font-size: 28px;\n      }\n\n      .pawosa-bowl-compare .pbc-subheading {\n        font-size: 13.5px;\n        margin-bottom: 15px;\n      }\n\n      .pawosa-bowl-compare .pbc-table {\n        grid-template-columns: 1.06fr 0.76fr 0.76fr;\n      }\n\n      .pawosa-bowl-compare .pbc-cell {\n        min-height: 48px;\n        padding: 9px 6px;\n        font-size: 11.5px;\n      }\n\n      .pawosa-bowl-compare .pbc-top {\n        min-height: 44px;\n        font-size: 9.5px;\n      }\n\n      .pawosa-bowl-compare .pbc-choice {\n        width: 64px;\n        grid-template-columns: 19px 1fr;\n        column-gap: 5px;\n      }\n\n      .pawosa-bowl-compare .pbc-mark {\n        width: 19px;\n        height: 19px;\n        font-size: 10px;\n      }\n\n      .pawosa-bowl-compare .pbc-choice span:last-child {\n        font-size: 11px;\n      }\n    }\n  </style>\n\n  <div class=\"pbc-shell\">\n    <h2 class=\"pbc-heading\">\n      Why Choose <span>Pawosa?</span>\n    </h2>\n\n    <p class=\"pbc-subheading\">\n      A smarter play bowl designed for hydration, stability, easy cleaning, and safer everyday fun.\n    </p>\n\n    <div class=\"pbc-table-wrap\" aria-label=\"Pawosa bowl comparison\">\n      <div class=\"pbc-table\">\n        <div class=\"pbc-cell pbc-feature pbc-top pbc-top-feature\">Feature</div>\n        <div class=\"pbc-cell pbc-brand pbc-top pbc-top-brand\">Pawosa</div>\n        <div class=\"pbc-cell pbc-basic pbc-top pbc-top-basic\">Basic Bowl</div>\n\n        <div class=\"pbc-cell pbc-feature\">Encourages hydration</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Yes</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>No</span>\n          </div>\n        </div>\n\n        <div class=\"pbc-cell pbc-feature\">Anti-slip design</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Stable</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>Slides</span>\n          </div>\n        </div>\n\n        <div class=\"pbc-cell pbc-feature\">Food-grade material</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Safe</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>Varies</span>\n          </div>\n        </div>\n\n        <div class=\"pbc-cell pbc-feature\">Easy to clean</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Easy</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>Basic</span>\n          </div>\n        </div>\n\n        <div class=\"pbc-cell pbc-feature\">Built for play</div>\n        <div class=\"pbc-cell pbc-brand\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-good\">✓</span>\n            <span>Fun</span>\n          </div>\n        </div>\n        <div class=\"pbc-cell pbc-basic\">\n          <div class=\"pbc-choice\">\n            <span class=\"pbc-mark pbc-mark-bad\">—</span>\n            <span>Limited</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>",
