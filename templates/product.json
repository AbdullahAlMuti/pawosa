        "custom_liquid_UienVc": {
          "type": "custom-liquid",
          "name": "Custom Liquid",
          "disabled": true,
          "settings": {
            "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@500;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .live-stock-row {\n    display: flex;\n    align-items: stretch;\n    width: 100%;\n    font-family: 'Nunito', sans-serif;\n    overflow: hidden;\n    gap: 0;\n  }\n\n  .live-col {\n    flex: 1 1 50%;\n    display: flex;\n    align-items: center;\n    min-width: 0;\n    position: relative;\n    padding: 8px 10px;\n  }\n\n  .live-col--viewers {\n    background: #EAF8EE;\n    justify-content: center;\n  }\n\n  .live-col--stock {\n    background: #FFECEC;\n    justify-content: center;\n  }\n\n  .live_visitors_gm {\n    position: relative;\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    padding-left: 12px;\n    margin: 0;\n    white-space: nowrap;\n    min-width: 0;\n    font-size: 12px;\n    font-weight: 700;\n    color: #187A34;\n    line-height: 1.2;\n  }\n\n  .live_visitors_gm::before {\n    position: absolute;\n    content: \"\";\n    width: 7px;\n    height: 7px;\n    background: #21b646;\n    box-shadow: 0 0 0 0 #21b646;\n    border-radius: 50%;\n    left: 0;\n    top: 50%;\n    transform: translateY(-50%);\n    animation: pulse-green 2s infinite;\n  }\n\n  @keyframes pulse-green {\n    0% {\n      transform: translateY(-50%) scale(0.95);\n      box-shadow: 0 0 0 0 rgba(33, 182, 70, 0.6);\n    }\n    70% {\n      transform: translateY(-50%) scale(1);\n      box-shadow: 0 0 0 8px rgba(33, 182, 70, 0);\n    }\n    100% {\n      transform: translateY(-50%) scale(0.95);\n      box-shadow: 0 0 0 0 rgba(33, 182, 70, 0);\n    }\n  }\n\n  .visitor_change_popup {\n    position: absolute;\n    left: 0;\n    top: 50%;\n    font-weight: 700;\n    font-size: 10px;\n    pointer-events: none;\n    opacity: 0;\n    white-space: nowrap;\n  }\n\n  .visitor_change_popup.pop-up {\n    animation: slideUp 1s ease-out forwards;\n    color: #21b646;\n  }\n\n  .visitor_change_popup.pop-down {\n    animation: slideDown 1s ease-out forwards;\n    color: #e74c3c;\n  }\n\n  @keyframes slideUp {\n    0% {\n      transform: translateY(-50%);\n      opacity: 1;\n    }\n    100% {\n      transform: translateY(calc(-50% - 16px));\n      opacity: 0;\n    }\n  }\n\n  @keyframes slideDown {\n    0% {\n      transform: translateY(-50%);\n      opacity: 1;\n    }\n    100% {\n      transform: translateY(calc(-50% + 16px));\n      opacity: 0;\n    }\n  }\n\n  .stock-inline {\n    position: relative;\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    white-space: nowrap;\n    min-width: 0;\n  }\n\n  .blink {\n    animation: blink-animation 1.8s ease-in-out infinite;\n    color: #cc0000;\n    font-size: 8px;\n    flex-shrink: 0;\n    line-height: 1;\n  }\n\n  @keyframes blink-animation {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.35; }\n  }\n\n  .text {\n    color: #AD0000;\n    font-family: 'Nunito', sans-serif;\n    font-weight: 700;\n    font-size: 12px;\n    white-space: nowrap;\n    line-height: 1.2;\n  }\n\n  .text span#stock-num {\n    display: inline-block;\n    min-width: 12px;\n    text-align: center;\n    transition: transform 0.28s ease, color 0.28s ease;\n  }\n\n  .text span#stock-num.bump {\n    transform: scale(1.14);\n    color: #8B0000;\n  }\n\n  .float-pop {\n    position: absolute;\n    top: -4px;\n    right: 10px;\n    font-family: 'Nunito', sans-serif;\n    font-size: 10px;\n    font-weight: 800;\n    color: #cc0000;\n    pointer-events: none;\n    animation: floatUp 1.4s ease-out forwards;\n    z-index: 10;\n    white-space: nowrap;\n  }\n\n  @keyframes floatUp {\n    0%   { opacity: 0; transform: translateY(4px) scale(0.96); }\n    20%  { opacity: 1; transform: translateY(0) scale(1); }\n    100% { opacity: 0; transform: translateY(-22px) scale(0.96); }\n  }\n\n  .shake {\n    animation: shake 0.28s ease;\n  }\n\n  @keyframes shake {\n    0%, 100% { transform: translateX(0); }\n    25% { transform: translateX(-1px); }\n    75% { transform: translateX(1px); }\n  }\n\n  @media (max-width: 768px) {\n    .live-col {\n      padding: 7px 8px;\n    }\n\n    .live_visitors_gm {\n      font-size: 11px;\n      gap: 4px;\n      padding-left: 11px;\n    }\n\n    .live_visitors_gm::before {\n      width: 6px;\n      height: 6px;\n    }\n\n    .text {\n      font-size: 11px;\n    }\n\n    .blink {\n      font-size: 7px;\n    }\n\n    .float-pop {\n      font-size: 9px;\n      right: 6px;\n    }\n  }\n</style>\n\n<div class=\"live-stock-row\">\n  <div class=\"live-col live-col--viewers\">\n    <p class=\"live_visitors_gm\">\n      <span id=\"visitors_count_gm\"></span> viewing now\n    </p>\n  </div>\n\n  <div class=\"live-col live-col--stock\">\n    <div class=\"stock-inline\" id=\"badge\">\n      <span class=\"blink\">&#9679;</span>\n      <span class=\"text\">Only <span id=\"stock-num\">21</span> left</span>\n    </div>\n  </div>\n</div>\n\n<script>\n  /* ===== VISITORS ===== */\n  (function () {\n    const minVisitors = 17;\n    const maxVisitors = 35;\n    const delay = 8000;\n\n    const visitorsCountEl = document.getElementById('visitors_count_gm');\n    const container = document.querySelector('.live_visitors_gm');\n\n    let currentCount = Math.floor(Math.random() * (maxVisitors - minVisitors + 1)) + minVisitors;\n    visitorsCountEl.textContent = currentCount;\n\n    function showChangePopup(change) {\n      const popup = document.createElement('span');\n      popup.className = 'visitor_change_popup';\n      popup.textContent = change > 0 ? `+${change}` : change;\n      popup.classList.add(change > 0 ? 'pop-up' : 'pop-down');\n\n      container.appendChild(popup);\n\n      setTimeout(function () {\n        popup.remove();\n      }, 1000);\n    }\n\n    function updateVisitors() {\n      const isAdding = Math.random() > 0.4;\n      const changeAmount = Math.floor(Math.random() * 3) + 1;\n\n      let change = isAdding ? changeAmount : -changeAmount;\n      let newCount = currentCount + change;\n\n      if (newCount < minVisitors) {\n        newCount = minVisitors;\n        change = newCount - currentCount;\n      } else if (newCount > maxVisitors) {\n        newCount = maxVisitors;\n        change = newCount - currentCount;\n      }\n\n      if (change !== 0) {\n        currentCount = newCount;\n        visitorsCountEl.textContent = currentCount;\n        showChangePopup(change);\n      }\n    }\n\n    setInterval(updateVisitors, delay);\n  })();\n\n  /* ===== STOCK ===== */\n  (function () {\n    var count = 21;\n    var minCount = 1;\n    var numEl = document.getElementById('stock-num');\n    var badge = document.getElementById('badge');\n    var wrap = document.querySelector('.live-col--stock');\n\n    function randBetween(a, b) {\n      return Math.floor(Math.random() * (b - a + 1)) + a;\n    }\n\n    function weightedDrop(currentCount) {\n      var r = Math.random();\n\n      if (currentCount <= 4) return 1;\n      if (currentCount <= 8) {\n        if (r < 0.8) return 1;\n        return 2;\n      }\n      if (currentCount <= 14) {\n        if (r < 0.7) return 1;\n        if (r < 0.93) return 2;\n        return 3;\n      }\n\n      if (r < 0.65) return 1;\n      if (r < 0.9) return 2;\n      if (r < 0.98) return 3;\n      return 4;\n    }\n\n    function spawnPop(drop) {\n      var pop = document.createElement('div');\n      pop.className = 'float-pop';\n      pop.textContent = '-' + drop;\n      pop.style.right = randBetween(6, 22) + 'px';\n      wrap.appendChild(pop);\n\n      setTimeout(function () {\n        pop.remove();\n      }, 1450);\n    }\n\n    function animateDrop(drop) {\n      numEl.textContent = count;\n\n      numEl.classList.remove('bump');\n      void numEl.offsetWidth;\n      numEl.classList.add('bump');\n\n      setTimeout(function () {\n        numEl.classList.remove('bump');\n      }, 280);\n\n      badge.classList.remove('shake');\n      void badge.offsetWidth;\n      badge.classList.add('shake');\n\n      setTimeout(function () {\n        badge.classList.remove('shake');\n      }, 300);\n\n      spawnPop(drop);\n    }\n\n    function getNextDelay(currentCount) {\n      if (currentCount <= 4) return randBetween(42000, 52000);\n      if (currentCount <= 8) return randBetween(40000, 48000);\n      if (currentCount <= 14) return randBetween(38000, 45000);\n      return randBetween(36000, 43000);\n    }\n\n    function drop() {\n      if (count <= minCount) return;\n\n      var d = weightedDrop(count);\n\n      if (count - d < minCount) {\n        d = count - minCount;\n      }\n\n      if (d < 1) return;\n\n      count -= d;\n      animateDrop(d);\n\n      if (count > minCount) {\n        setTimeout(drop, getNextDelay(count));\n      }\n    }\n\n    setTimeout(drop, randBetween(12000, 20000));\n  })();\n</script>"
