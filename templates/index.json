oke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n          30-Day Guarantee\n        </span>\n\n        <span class=\"hero__trust-item\">\n          <span class=\"hero__dot hero__dot--coral\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 10 10\" fill=\"none\">\n              <path d=\"M2 5l2.2 2.5 3.8-4\" stroke=\"#c94040\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n          Loved by Pet Parents\n        </span>\n      </div>\n\n      <div class=\"hero__rating\" aria-label=\"Rated 4.9 out of 5 by 12,500+ customers\">\n        <div class=\"hero__stars\" aria-hidden=\"true\">\n          <span class=\"hero__star\">★</span>\n          <span class=\"hero__star\">★</span>\n          <span class=\"hero__star\">★</span>\n          <span class=\"hero__star\">★</span>\n          <span class=\"hero__star\">★</span>\n        </div>\n\n        <span class=\"hero__rating-text\">4.9 / 5 &nbsp;·&nbsp; 12,500+ happy pet parents</span>\n      </div>\n\n    </div>\n\n    <!-- FEATURE BAR -->\n    <div class=\"hero__features\" role=\"list\" aria-label=\"Key benefits\">\n\n      <div class=\"hero__feature\" role=\"listitem\">\n        <span class=\"hero__ficon hero__ficon--green\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M12 3 20 6.5v5.2c0 4.7-3.3 8.1-8 9.3-4.7-1.2-8-4.6-8-9.3V6.5L12 3Z\" stroke=\"currentColor\" stroke-width=\"1.8\"/>\n            <path d=\"M8.7 11.8 10.8 14l4.5-4.8\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </span>\n\n        <div>\n          <p class=\"hero__ft\">Vet Approved</p>\n          <p class=\"hero__fd\">Recommended by vets</p>\n        </div>\n      </div>\n\n      <div class=\"hero__feature\" role=\"listitem\">\n        <span class=\"hero__ficon hero__ficon--blue\" aria-hidden=\"t