        "custom_liquid": "<style>\n  .paw-offer-section {\n    --cream: #fff6ed;\n    --white: #ffffff;\n    --dark: #120b07;\n    --text: #2f241d;\n    --muted: #4a372c;\n    --orange: #ff6428;\n    --orange-dark: #d9410b;\n\n    width: 100%;\n    max-width: 100%;\n    margin: 0 auto;\n    background: var(--cream);\n    font-family: \"Arial Rounded MT Bold\", Arial, Helvetica, sans-serif;\n    color: var(--text);\n    overflow: hidden;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .paw-offer-section *,\n  .paw-offer-section *::before,\n  .paw-offer-section *::after {\n    box-sizing: border-box;\n  }\n\n  .paw-offer-wrap {\n    width: 100%;\n    max-width: 430px;\n    margin: 0 auto;\n    padding: clamp(14px, 4vw, 22px);\n  }\n\n  .paw-hero-grid {\n    display: grid;\n    grid-template-columns: 1.04fr 0.96fr;\n    gap: 6px;\n    align-items: start;\n    position: relative;\n  }\n\n  .paw-hero-copy {\n    position: relative;\n    z-index: 3;\n    min-width: 0;\n  }\n\n  .paw-trust-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    background: var(--white);\n    border-radius: 999px;\n    padding: 5px 9px;\n    margin-bottom: 12px;\n    box-shadow: 0 2px 8px rgba(60, 35, 20, 0.08);\n    white-space: nowrap;\n  }\n\n  .paw-trust-check {\n    width: 14px;\n    height: 14px;\n    border-radius: 50%;\n    background: #78a83c;\n    display: grid;\n    place-items: center;\n    color: #fff;\n    font-size: 9px;\n    font-weight: 900;\n    flex: 0 0 auto;\n  }\n\n  .paw-avatars {\n    display: flex;\n  }\n\n  .paw-avatar {\n    width: 16px;\n    height: 16px;\n    border: 1.5px solid #fff;\n    border-radius: 50%;\n    margin-left: -5px;\n    background: linear-gradient(135deg, #f2c28c, #b86d42);\n  }\n\n  .paw-avatar:first-child {\n    margin-left: 0;\n  }\n\n  .paw-avatar:nth-child(2) {\n    background: linear-gradient(135deg, #d9a06c, #895b3c);\n  }\n\n  .paw-avatar:nth-child(3) {\n    background: linear-gradient(135deg, #f3d18d, #d57b4