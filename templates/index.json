e\">\n          <path d=\"M4 13h9V7l7 5-7 5v-4H4z\" fill=\"#f3a228\"/>\n        </svg>\n        <span>Fast<br>Delivery</span>\n      </div>\n\n      <div class=\"paw-feature\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\">\n          <path d=\"M12 4a8 8 0 108 8\" stroke=\"#8bbb4a\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n          <path d=\"M12 1v4M12 12l3-2\" stroke=\"#8bbb4a\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n        <span>7-Day Easy<br>Returns</span>\n      </div>\n    </div>\n\n    <div class=\"paw-offer-card\">\n      <div class=\"paw-offer-top\">\n        <div class=\"paw-discount\">\n          <div class=\"paw-limited\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\">\n              <path d=\"M12 7v5l3 2\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n              <circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"currentColor\" stroke-width=\"2\"/>\n            </svg>\n            Limited Time Offer\n          </div>\n\n          <strong>20% OFF</strong>\n          <b>Your First Order</b>\n          <div class=\"paw-code\">Use Code: PAWHAPPY20</div>\n        </div>\n\n        <div class=\"paw-timer\">\n          <h3 class=\"paw-timer-title\">Offer Ends In</h3>\n\n          <div class=\"paw-time-row\">\n            <div class=\"paw-time-unit\">\n              <span class=\"paw-time-number\" id=\"paw-hours\">03</span>\n            </div>\n\n            <span class=\"paw-time-separator\">:</span>\n\n            <div class=\"paw-time-unit\">\n              <span class=\"paw-time-number\" id=\"paw-minutes\">42</span>\n            </div>\n\n            <span class=\"paw-time-separator\">:</span>\n\n            <div class=\"paw-time-unit\">\n              <span class=\"paw-time-number\" id=\"paw-seconds\">37</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"paw-cta-wrap\">\n        <a href=\"https://pawosa.com/checkouts/cn/hWNCBLnEUvkdqVlIQVMn9Kzc\" class=\"paw-cta\">\n          <span class=\"paw-cta-icon\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\">\n              <circle cx=\"8\" cy=\"8\" r=\"3\" fill=\"currentColor\"/>\n              <circle cx=\"16\" cy=\"8\" r=\"3\" fill=\"currentColor\"/>\n              <circle cx=\"6.5\" cy=\"15.5\" r=\"3\" fill=\"currentColor\"/>\n              <circle cx=\"17.5\" cy=\"15.5\" r=\"3\" fill=\"currentColor\"/>\n              <path d=\"M12 10.5c-1.6 0-3 1.1-3.4 2.7-.2.9.4 1.8 1.4 1.8h4c1 0 1.6-.9 1.4-1.8-.4-1.6-1.8-2.7-3.4-2.7z\" fill=\"currentColor\"/>\n            </svg>\n          </span>\n\n          <span class=\"paw-cta-text\">Claim 20% Off</span>\n\n          <span class=\"paw-cta-icon\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\">\n              <path d=\"M5 12h14M13 5l7 7-7 7\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </span>\n        </a>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  (function () {\n    const section = document.currentScript.previousElementSibling;\n    if (!section) return;\n\n    const hoursEl = section.querySelector(\"#paw-hours\");\n    const minutesEl = section.querySelector(\"#paw-minutes\");\n    const secondsEl = section.querySelector(\"#paw-seconds\");\n\n    if (!hoursEl || !minutesEl || !secondsEl) return;\n\n    const storageKey = \"paw_offer_countdown_end\";\n    const countdownDuration = (3 * 60 * 60) + (42 * 60) + 37;\n\n    let endTime = Number(localStorage.getItem(storageKey));\n\n    if (!endTime || endTime <= Date.now()) {\n      endTime = Date.now() + countdownDuration * 1000;\n      localStorage.setItem(storageKey, String(endTime));\n    }\n\n    function updateTimer() {\n      const totalSeconds = Math.max(0, Math.floor((endTime - Date.now()) / 1000));\n\n      hoursEl.textContent = String(Math.floor(totalSeconds / 3600)).padStart(2, \"0\");\n      minutesEl.textContent = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, \"0\");\n      secondsEl.textContent = String(totalSeconds % 60).padStart(2, \"0\");\n\n      if (totalSeconds <= 0) {\n        clearInterval(timer);\n        localStorage.removeItem(storageKey);\n      }\n    }\n\n    updateTimer();\n    const timer = setInterval(updateTimer, 1000);\n  })();\n</script>",
