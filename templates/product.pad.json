\">\n      <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n        <path d=\"M6 13c2-4 10-4 12 0\"></path>\n        <path d=\"M7 16c2-2 8-2 10 0\"></path>\n        <path d=\"M8 19c2-1 6-1 8 0\"></path>\n      </svg>\n    </span>\n    <span class=\"feature-label\">Ultra<br>Absorbent</span>\n  </div>\n\n  <div class=\"feature-item\">\n    <span class=\"feature-icon\">\n      <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n        <path d=\"M12 4c3 2 5 5 5 8a5 5 0 0 1-10 0c0-3 2-6 5-8z\"></path>\n        <path d=\"M9 16l6-6\"></path>\n      </svg>\n    </span>\n    <span class=\"feature-label\">Locks In<br>Odor</span>\n  </div>\n\n  <div class=\"feature-item\">\n    <span class=\"feature-icon\">\n      <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n        <path d=\"M6 15l4-4\"></path>\n        <path d=\"M14 15l4-4\"></path>\n        <path d=\"M4 19h16\"></path>\n      </svg>\n    </span>\n    <span class=\"feature-label\">Slip-Resistant<br>Base</span>\n  </div>\n</div><br>"
