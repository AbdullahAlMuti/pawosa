        "custom_liquid_XbTyaT": {
          "type": "custom-liquid",
          "name": "Custom Liquid",
          "settings": {
            "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@500;700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .stock-wrap {\n    position: relative;\n    display: flex;\n    justify-content: center;\n    width: 100%;\n  }\n\n  .red-div {\n    background-color: #ffcccc;\n    padding: 7px 16px;\n    border-radius: 999px;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    width: 100%;\n    max-width: 340px;\n    justify-content: center;\n    position: relative;\n    overflow: visible;\n  }\n\n  .blink {\n    animation: blink-animation 1.8s ease-in-out infinite;\n    color: #cc0000;\n    font-size: 10px;\n    flex-shrink: 0;\n    line-height: 1;\n  }\n\n  @keyframes blink-animation {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.35; }\n  }\n\n  .text {\n    color: #AD0000;\n    font-family: 'Nunito', sans-serif;\n    font-weight: 700;\n    font-size: 13px;\n    white-space: nowrap;\n  }\n\n  .text span#stock-num {\n    display: inline-block;\n    min-width: 14px;\n    text-align: center;\n    transition: transform 0.28s ease, color 0.28s ease;\n  }\n\n  .text span#stock-num.bump {\n    transform: scale(1.18);\n    color: #8B0000;\n  }\n\n  .float-pop {\n    position: absolute;\n    top: -6px;\n    right: 24px;\n    font-family: 'Nunito', sans-serif;\n    font-size: 11px;\n    font-weight: 800;\n    color: #cc0000;\n    pointer-events: none;\n    animation: floatUp 1.4s ease-out forwards;\n    z-index: 10;\n  }\n\n  @keyframes floatUp {\n    0%   { opacity: 0; transform: translateY(4px) scale(0.96); }\n    20%  { opacity: 1; transform: translateY(0) scale(1); }\n    100% { opacity: 0; transform: translateY(-26px) scale(0.96); }\n  }\n\n  .shake {\n    animation: shake 0.28s ease;\n  }\n\n  @keyframes shake {\n    0%, 100% { transform: translateX(0); }\n    25% { transform: translateX(-2px); }\n    75% { transform: translateX(2px); }\n  }\n\n  @media (max-width: 768px) {\n    .red-div {\n      max-width: 100%;\n      padding: 8px 12px;\n    }\n\n    .text {\n      font-size: 12px;\n      white-space: normal;\n      text-align: center;\n      line-height: 1.3;\n    }\n  }\n</style>\n\n<div class=\"stock-wrap\">\n  <div class=\"red-div\" id=\"badge\">\n    <span class=\"blink\">&#9679;</span>\n    <span class=\"text\">Only <span id=\"stock-num\">21</span> bags left at this price.</span>\n  </div>\n</div>\n\n<script>\n(function () {\n  var count = 21;\n  var minCount = 1;\n  var numEl = document.getElementById('stock-num');\n  var badge = document.getElementById('badge');\n  var wrap = document.querySelector('.stock-wrap');\n\n  function randBetween(a, b) {\n    return Math.floor(Math.random() * (b - a + 1)) + a;\n  }\n\n  function weightedDrop(currentCount) {\n    var r = Math.random();\n\n    if (currentCount <= 4) return 1;\n    if (currentCount <= 8) {\n      if (r < 0.8) return 1;\n      return 2;\n    }\n    if (currentCount <= 14) {\n      if (r < 0.7) return 1;\n      if (r < 0.93) return 2;\n      return 3;\n    }\n\n    if (r < 0.65) return 1;\n    if (r < 0.9) return 2;\n    if (r < 0.98) return 3;\n    return 4;\n  }\n\n  function spawnPop(drop) {\n    var pop = document.createElement('div');\n    pop.className = 'float-pop';\n    pop.textContent = '-' + drop;\n    pop.style.right = randBetween(18, 60) + 'px';\n    wrap.appendChild(pop);\n\n    setTimeout(function () {\n      pop.remove();\n    }, 1450);\n  }\n\n  function animateDrop(drop) {\n    numEl.textContent = count;\n\n    numEl.classList.remove('bump');\n    void numEl.offsetWidth;\n    numEl.classList.add('bump');\n\n    setTimeout(function () {\n      numEl.classList.remove('bump');\n    }, 280);\n\n    badge.classList.remove('shake');\n    void badge.offsetWidth;\n    badge.classList.add('shake');\n\n    setTimeout(function () {\n      badge.classList.remove('shake');\n    }, 300);\n\n    spawnPop(drop);\n  }\n\n  function getNextDelay(currentCount) {\n    if (currentCount <= 4) return randBetween(42000, 52000);\n    if (currentCount <= 8) return randBetween(40000, 48000);\n    if (currentCount <= 14) return randBetween(38000, 45000);\n    return randBetween(36000, 43000);\n  }\n\n  function drop() {\n    if (count <= minCount) return;\n\n    var d = weightedDrop(count);\n\n    if (count - d < minCount) {\n      d = count - minCount;\n    }\n\n    if (d < 1) return;\n\n    count -= d;\n    animateDrop(d);\n\n    if (count > minCount) {\n      setTimeout(drop, getNextDelay(count));\n    }\n  }\n\n  setTimeout(drop, randBetween(12000, 20000));\n})();\n</script>"
          },
          "blocks": {}
        },
